# ============================================
# HEALTH CHECK
# ============================================

cmd_health()
{
  # Parse command-specific parameters
  local sections="version,database,uptime,connections,cache,storage,blocking" format="table"

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --sections) sections="$2"; shift 2 ;;
      -f|--format) format="$2"; shift 2 ;;
      *) shift ;;
    esac
  done

  # Parse sections list
  local SECTION_LIST
  IFS=',' SECTION_LIST=($sections)

  # Helper function to check if section is enabled
  section_enabled() {
    local sec="$1"
    for s in "${SECTION_LIST[@]}"; do
      [[ "$s" == "$sec" ]] && return 0
    done
    return 1
  }

  colorize blue "=== PostgreSQL Health Check ==="
  echo ""

  if section_enabled "version"; then
    q "SELECT 'Version' AS check, version() AS status;"
  fi

  if section_enabled "database"; then
    q "SELECT 'Database' AS check, current_database() AS status;"
  fi

  if section_enabled "uptime"; then
    q "SELECT 'Uptime' AS check, date_trunc('second', now() - pg_postmaster_start_time())::text AS status;"
    echo ""
  fi

  if section_enabled "connections"; then
    q "SELECT 'Connections' AS check,
         count(*) || ' total, ' ||
         count(*) FILTER(WHERE state='active') || ' active, ' ||
         count(*) FILTER(WHERE state='idle in transaction') || ' idle_tx'
       AS status FROM pg_stat_activity;"
  fi

  if section_enabled "cache"; then
    q "SELECT 'Cache Hit' AS check,
         round(100.0 * blks_hit / nullif(blks_hit + blks_read, 0), 2) || '%' AS status
       FROM pg_stat_database WHERE datname = current_database();"
  fi

  if section_enabled "storage"; then
    q "SELECT 'Dead Tuples' AS check,
         sum(n_dead_tup) || ' across ' || count(*) || ' tables' AS status
       FROM pg_stat_user_tables;"
    q "SELECT 'Unused Indexes' AS check, count(*) || ' indexes' AS status
       FROM pg_stat_user_indexes ui
       JOIN pg_index i ON ui.indexrelid = i.indexrelid
       WHERE NOT i.indisunique
         AND idx_scan < 50
         AND pg_relation_size(i.indexrelid) > 1024 * 1024;"
  fi

  if section_enabled "blocking"; then
    q "SELECT 'Blocking' AS check,
         count(*) FILTER(WHERE array_length(pg_blocking_pids(pid),1) > 0) || ' sessions' AS status
       FROM pg_stat_activity;"
  fi
}

