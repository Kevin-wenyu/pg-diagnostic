cmd_lock_graph()
{
  q "WITH RECURSIVE lock_chains AS (
       -- Base case: blocking relationships
       SELECT blocked.pid AS root_pid,
              blocked.pid,
              blocking.pid AS blocker_pid,
              1 AS level,
              ARRAY[blocked.pid] AS path,
              blocked.usename AS blocked_user,
              blocking.usename AS blocking_user,
              blocked.query AS blocked_query,
              blocking.query AS blocking_query,
              now() - blocked.query_start AS blocked_duration
       FROM pg_stat_activity blocked
       JOIN pg_stat_activity blocking ON blocking.pid = ANY(pg_blocking_pids(blocked.pid))
       WHERE blocked.state = 'active'

       UNION ALL

       -- Recursive case: continue up the chain
       SELECT lc.root_pid,
              blocked.pid,
              blocking.pid AS blocker_pid,
              lc.level + 1,
              lc.path || blocked.pid,
              blocked.usename AS blocked_user,
              blocking.usename AS blocking_user,
              blocked.query AS blocked_query,
              blocking.query AS blocking_query,
              now() - blocked.query_start AS blocked_duration
       FROM lock_chains lc
       JOIN pg_stat_activity blocked ON blocked.pid = ANY(pg_blocking_pids(lc.pid))
       JOIN pg_stat_activity blocking ON blocking.pid = ANY(pg_blocking_pids(blocked.pid))
       WHERE blocked.state = 'active'
         AND NOT (blocked.pid = ANY(lc.path))  -- Prevent cycles
         AND lc.level < 10  -- Prevent infinite recursion
     )
     SELECT root_pid AS chain_root,
            pid AS blocked_pid,
            blocker_pid,
            level,
            blocked_user,
            blocking_user,
            blocked_duration,
            LEFT(blocked_query, 80) AS blocked_query
     FROM lock_chains
     ORDER BY chain_root, level, blocked_duration DESC;"
}

