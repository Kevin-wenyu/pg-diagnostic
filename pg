  workflow_step 2 3 "Connection by Application"

  echo "   Top connection sources:"
  q "SELECT
    COALESCE(application_name, 'unknown') as app,
    COALESCE(usename, 'unknown') as user,
    client_addr,
    count(*) as connections,
    count(*) FILTER (WHERE state = 'active') as active,
    count(*) FILTER (WHERE state = 'idle in transaction') as idle_in_tx
  FROM pg_stat_activity
  GROUP BY application_name, usename, client_addr
  ORDER BY count(*) DESC
  LIMIT 10;"

  # Step 3: Connection limits
  workflow_step 3 3 "Connection Limit Analysis"

  echo "   Per-database connection usage:"
  q "SELECT
    datname,
    count(*) as current,
    (SELECT setting::int FROM pg_settings WHERE name = 'max_connections') as max_conn,
    round((100.0 * count(*) / (SELECT setting::int FROM pg_settings WHERE name = 'max_connections'))::numeric, 2) as pct
  FROM pg_stat_activity
  GROUP BY datname
  ORDER BY count(*) DESC;"

  echo ""
  colorize yellow "💡 Recommendations:"
  echo "   1. Consider connection pooling (PgBouncer/pgpool)"
  echo "   2. Set appropriate max_connections for your workload"
  echo "   3. Monitor idle_in_transaction sessions"
  echo "   4. Review applications with excessive connections"
  echo ""
}

