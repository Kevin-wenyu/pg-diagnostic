cmd_explain()
{
  local sql="$*"
  local analyze_mode=false

  # Check if first argument is 'analyze' keyword (case-insensitive)
  local first_arg_lower
  first_arg_lower=$(echo "$1" | tr '[:upper:]' '[:lower:]')
  if [ "$first_arg_lower" = "analyze" ]; then
    analyze_mode=true
    shift
    sql="$*"
  fi

  [ -z "$sql" ] && { echo "Usage: $EXEC_NAME explain [analyze] \"<SQL>\""; return 1; }

  # Basic SQL validation to prevent harmful statements
  local sql_upper
  sql_upper=$(echo "$sql" | tr '[:lower:]' '[:upper:]')
  if [[ "$sql_upper" =~ ^(INSERT|UPDATE|DELETE|DROP|CREATE|ALTER|TRUNCATE|GRANT|REVOKE|COMMIT|ROLLBACK|BEGIN|START TRANSACTION|SET|SHOW|RESET) ]]; then
    echo "Error: Only SELECT statements are allowed in explain mode for security reasons" >&2
    return 1
  fi

  # Validate SQL contains only safe characters for SELECT statements
  if [[ ! "$sql" =~ ^[[:space:]]*[Ss][Ee][Ll][Ee][Cc][Tt] ]]; then
    echo "Error: Only SELECT statements are allowed" >&2
    return 1
  fi

  # Do NOT use q_sanitize on full SQL - it corrupts SQL syntax (= becomes _)
  # The SQL is passed directly as it has been validated above
  if [ "$analyze_mode" = true ]; then
    echo "=== EXECUTION PLAN ==="
    echo ""
    q "EXPLAIN (ANALYZE, BUFFERS, FORMAT TEXT) $sql;"
    echo ""
    echo "=== EXECUTION RESULT ==="
    echo ""
    q "$sql;"
  else
    q "EXPLAIN (ANALYZE, BUFFERS, FORMAT TEXT) $sql;"
  fi
}

