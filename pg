# ============================================
# WORKFLOW - INTELLIGENT DIAGNOSIS WORKFLOW
# ============================================

cmd_workflow()
{
  local action="${1:-auto}"
  shift || true

  case "$action" in
    auto|detect|scan)    workflow_auto_detect "$@" ;;
    slow|slow_query)     workflow_slow_query "$@" ;;
    lock|blocking)       workflow_lock_issue "$@" ;;
    conn|connection)     workflow_connection "$@" ;;
    io|performance)      workflow_io_performance "$@" ;;
    full|complete)       workflow_full_diagnosis "$@" ;;
    *)
      echo "Usage: $EXEC_NAME workflow <action> [options]"
      echo ""
      echo "Actions:"
      echo "  auto              Auto-detect database issues (default)"
      echo "  slow_query [pid]  Deep diagnosis for slow query issues"
      echo "  lock              Diagnose lock and blocking issues"
      echo "  connection        Diagnose connection pool issues"
      echo "  io                Diagnose I/O performance issues"
      echo "  full              Complete comprehensive diagnosis"
      echo ""
      echo "Examples:"
      echo "  $EXEC_NAME workflow auto"
      echo "  $EXEC_NAME workflow slow_query"
      echo "  $EXEC_NAME workflow lock"
      echo "  $EXEC_NAME workflow full"
      ;;
  esac
}

# Print workflow step header
workflow_step()
{
  local step_num="$1"
  local total="$2"
  local title="$3"
  echo ""
  colorize yellow "📊 Step $step_num/$total: $title"
  echo ""
}

# Print workflow result
workflow_result()
{
  local status="$1"
  local message="$2"
  case "$status" in
    ok|good|green)
      echo "   ✅ $message"
      ;;
    warn|warning|yellow)
      echo "   ⚠️  $message"
      ;;
    critical|error|red)
      echo "   ❌ $message"
      ;;
    info|blue)
      echo "   ℹ️  $message"
      ;;
  esac
}

# ============================================
# AUTO DETECT - Automatic issue detection
# ============================================

workflow_auto_detect()
{
  echo ""
  echo "╔════════════════════════════════════════════════════════════════╗"
  echo "║          🔍 INTELLIGENT DATABASE DIAGNOSIS                      ║"
  echo "╚════════════════════════════════════════════════════════════════╝"
  echo ""
  echo "Started at: $(date '+%Y-%m-%d %H:%M:%S')"
  echo "Database: $DBNAME @ $DBHOST:$DBPORT"
  echo "PostgreSQL: $(q_scalar "SELECT version();" 2>/dev/null | head -1)"
  echo ""
  print_separator 70

  local issues_found=0
  local warnings_found=0
  local critical_issues=""
  local recommendations=""

  # Step 1: Connection Health
  workflow_step 1 5 "Connection Health Check"
  local current_conn max_conn conn_pct
  current_conn=$(q_scalar "SELECT count(*) FROM pg_stat_activity;" 2>/dev/null || echo 0)
  max_conn=$(q_scalar "SELECT setting::int FROM pg_settings WHERE name = 'max_connections';" 2>/dev/null || echo 100)

  if [[ "$current_conn" =~ ^[0-9]+$ ]] && [[ "$max_conn" =~ ^[0-9]+$ ]] && [ "$max_conn" -gt 0 ]; then
    conn_pct=$(( current_conn * 100 / max_conn ))
    echo "   Connections: $current_conn / $max_conn ($(format_percent $conn_pct))"

    if [ "$conn_pct" -gt 90 ]; then
      workflow_result critical "CRITICAL: Connection usage > 90%"
      issues_found=$((issues_found + 1))
      critical_issues="${critical_issues}Connection exhaustion (90%+);"
      recommendations="${recommendations}Increase max_connections or implement connection pooling;"
    elif [ "$conn_pct" -gt 75 ]; then
      workflow_result warning "WARNING: Connection usage > 75%"
      warnings_found=$((warnings_found + 1))
    else
      workflow_result ok "Connection usage healthy"
    fi
  fi

  # Check idle in transaction
  local idle_tx
  idle_tx=$(q_scalar "SELECT count(*) FROM pg_stat_activity WHERE state = 'idle in transaction';" 2>/dev/null || echo 0)
  if [[ "$idle_tx" =~ ^[0-9]+$ ]] && [ "$idle_tx" -gt 0 ]; then
    if [ "$idle_tx" -gt 5 ]; then
      workflow_result warning "$idle_tx sessions idle in transaction"
      warnings_found=$((warnings_found + 1))
      recommendations="${recommendations}Review idle transactions; consider setting idle_in_transaction_session_timeout;"
    else
      workflow_result info "$idle_tx sessions idle in transaction"
    fi
  fi

  # Step 2: Slow Query Detection
  workflow_step 2 5 "Slow Query Analysis"
  local slow_count
  slow_count=$(q_scalar "SELECT count(*) FROM pg_stat_activity WHERE state = 'active' AND now() - query_start > interval '5 seconds';" 2>/dev/null || echo 0)

  if [[ "$slow_count" =~ ^[0-9]+$ ]] && [ "$slow_count" -gt 0 ]; then
    workflow_result warning "Found $slow_count slow queries (running > 5s)"
    issues_found=$((issues_found + 1))
    critical_issues="${critical_issues}Slow queries detected;"

    # Get slowest query sample
    local slow_query
    slow_query=$(q_scalar "SELECT LEFT(query, 80) FROM pg_stat_activity WHERE state = 'active' AND now() - query_start > interval '5 seconds' ORDER BY now() - query_start DESC LIMIT 1;" 2>/dev/null)
    if [ -n "$slow_query" ]; then
      echo "   Slowest: ${slow_query}..."
    fi
    recommendations="${recommendations}Run 'pg workflow slow_query' for detailed analysis;"
  else
    workflow_result ok "No slow queries detected"
  fi

  # Step 3: Lock & Blocking Analysis
  workflow_step 3 5 "Lock & Blocking Check"
  local blocked_count blocking_count
  blocked_count=$(q_scalar "SELECT count(*) FROM pg_locks WHERE NOT granted;" 2>/dev/null || echo 0)
  blocking_count=$(q_scalar "SELECT count(DISTINCT blocking_pid) FROM pg_locks blocked JOIN pg_locks blocking ON blocked.locktype = blocking.locktype AND blocked.relation = blocking.relation WHERE blocked.granted = false AND blocking.granted = true;" 2>/dev/null || echo 0)

  if [[ "$blocked_count" =~ ^[0-9]+$ ]] && [ "$blocked_count" -gt 0 ]; then
    workflow_result critical "CRITICAL: $blocked_count blocked sessions"
    issues_found=$((issues_found + 1))
    critical_issues="${critical_issues}Lock blocking issues;"
    recommendations="${recommendations}Run 'pg workflow lock' for lock analysis; consider terminating blocking sessions;"
  elif [[ "$blocking_count" =~ ^[0-9]+$ ]] && [ "$blocking_count" -gt 0 ]; then
    workflow_result warning "$blocking_count blocking sessions"
    warnings_found=$((warnings_found + 1))
  else
    workflow_result ok "No blocking issues"
  fi

  # Step 4: Cache & I/O Health
  workflow_step 4 5 "Cache & I/O Health"
  local cache_ratio
  cache_ratio=$(q_scalar "SELECT round(100.0 * sum(blks_hit) / nullif(sum(blks_hit) + sum(blks_read), 0), 2) FROM pg_stat_database WHERE datname not in ('template0', 'template1');" 2>/dev/null)

  if [ -n "$cache_ratio" ] && [[ "$cache_ratio" =~ ^[0-9]+\.?[0-9]*$ ]]; then
    echo "   Cache hit ratio: $(format_percent "$cache_ratio")"

    if (( $(echo "$cache_ratio < 85" | bc -l) )); then
      workflow_result critical "CRITICAL: Cache hit ratio < 85%"
      issues_found=$((issues_found + 1))
      critical_issues="${critical_issues}Low cache hit ratio;"
      recommendations="${recommendations}Increase shared_buffers; review queries causing sequential scans;"
    elif (( $(echo "$cache_ratio < 95" | bc -l) )); then
      workflow_result warning "Cache hit ratio below optimal (< 95%)"
      warnings_found=$((warnings_found + 1))
    else
      workflow_result ok "Cache hit ratio excellent"
    fi
  fi

  # Check wait events
  if [ "$PG_MAJOR_VERSION" -ge 10 ]; then
    local io_wait_pct
    io_wait_pct=$(q_scalar "SELECT round(100.0 * count(*) / nullif((SELECT count(*) FROM pg_stat_activity WHERE state = 'active'), 0), 1) FROM pg_stat_activity WHERE wait_event_type = 'IO';" 2>/dev/null || echo 0)

    if [[ "$io_wait_pct" =~ ^[0-9]+\.?[0-9]*$ ]] && (( $(echo "$io_wait_pct > 30" | bc -l) )); then
      workflow_result warning "High I/O wait: ${io_wait_pct}%"
      warnings_found=$((warnings_found + 1))
      recommendations="${recommendations}Review I/O performance; consider faster storage or query optimization;"
    fi
  fi

  # Step 5: Table Health
  workflow_step 5 5 "Table Health Check"
  local bloated_tables vacuum_needed
  bloated_tables=$(q_scalar "SELECT count(*) FROM pg_stat_user_tables WHERE n_dead_tup > 10000;" 2>/dev/null || echo 0)
  vacuum_needed=$(q_scalar "SELECT count(*) FROM pg_stat_user_tables WHERE n_dead_tup > 1000 AND (last_vacuum IS NULL AND last_autovacuum IS NULL);" 2>/dev/null || echo 0)

  if [[ "$bloated_tables" =~ ^[0-9]+$ ]] && [ "$bloated_tables" -gt 0 ]; then
    if [ "$bloated_tables" -gt 10 ]; then
      workflow_result warning "$bloated_tables tables need vacuum (high dead tuples)"
      warnings_found=$((warnings_found + 1))
      recommendations="${recommendations}Run VACUUM on tables with high dead tuples;"
    else
      workflow_result info "$bloated_tables tables with dead tuples"
    fi
  fi

  if [[ "$vacuum_needed" =~ ^[0-9]+$ ]] && [ "$vacuum_needed" -gt 0 ]; then
    workflow_result warning "$vacuum_needed tables never vacuumed"
    recommendations="${recommendations}Ensure autovacuum is enabled; manually vacuum stale tables;"
  fi

  # Summary
  echo ""
  print_separator 70
  echo ""
  colorize yellow "📋 DIAGNOSIS SUMMARY"
  echo ""

  if [ $issues_found -eq 0 ] && [ $warnings_found -eq 0 ]; then
    colorize green "   ✅ Database health: EXCELLENT"
    echo "   No issues detected. Database is running optimally."
  elif [ $issues_found -eq 0 ]; then
    colorize yellow "   ⚠️  Database health: GOOD (with warnings)"
    echo "   Warnings found: $warnings_found"
  else
    colorize red "   ❌ Database health: NEEDS ATTENTION"
    echo "   Critical issues: $issues_found"
    echo "   Warnings: $warnings_found"
  fi

  echo ""

  # Show critical issues
  if [ -n "$critical_issues" ]; then
    colorize red "🚨 Critical Issues Detected:"
    echo "$critical_issues" | tr ';' '\n' | while read -r issue; do
      [ -n "$issue" ] && echo "   • $issue"
    done
    echo ""
  fi

  # Show recommendations
  if [ -n "$recommendations" ]; then
    colorize yellow "💡 Recommended Actions:"
    echo "$recommendations" | tr ';' '\n' | while read -r rec; do
      [ -n "$rec" ] && echo "   • $rec"
    done
    echo ""
  fi

  # Quick action suggestions
  echo ""
  colorize blue "🔧 Quick Actions:"
  echo "   • pg workflow slow_query  - Deep dive into slow queries"
  echo "   • pg workflow lock        - Analyze lock issues"
  echo "   • pg workflow connection  - Check connection details"
  echo "   • pg blocking             - See blocking sessions"
  echo "   • pg tune score           - Get configuration score"
  echo ""

  print_separator 70
  echo ""
}

# ============================================
# SLOW QUERY WORKFLOW
# ============================================

workflow_slow_query()
{
  local target_pid="$1"

  echo ""
  echo "╔════════════════════════════════════════════════════════════════╗"
  echo "║          🐌 SLOW QUERY DIAGNOSIS WORKFLOW                       ║"
  echo "╚════════════════════════════════════════════════════════════════╝"
  echo ""

  # Step 1: Check pg_stat_statements
  workflow_step 1 4 "pg_stat_statements Analysis"

  local has_pgss
  has_pgss=$(q_scalar "SELECT 1 FROM pg_extension WHERE extname = 'pg_stat_statements';" 2>/dev/null)

  if [ "$has_pgss" = "1" ]; then
    workflow_result ok "pg_stat_statements extension is active"
    echo ""
    echo "   Top 5 slowest queries by total time:"
    q "SELECT
      LEFT(query, 60) as query_preview,
      calls,
      round(${PGS_TOTAL_COL:-total_exec_time}::numeric, 2) as total_ms,
      round(mean_exec_time::numeric, 2) as avg_ms,
      round((100.0 * ${PGS_TOTAL_COL:-total_exec_time} / (SELECT sum(${PGS_TOTAL_COL:-total_exec_time}) FROM pg_stat_statements))::numeric, 2) as pct_time
    FROM pg_stat_statements
    WHERE query NOT LIKE '%pg_stat_statements%'
    ORDER BY ${PGS_TOTAL_COL:-total_exec_time} DESC
    LIMIT 5;"
  else
    workflow_result warning "pg_stat_statements not installed"
    echo "   Consider installing: CREATE EXTENSION pg_stat_statements;"
  fi

  # Step 2: Current slow queries
  workflow_step 2 4 "Current Slow Queries"

  if [ -n "$target_pid" ]; then
    echo "   Analyzing specific PID: $target_pid"
    q "SELECT
      pid,
      now() - query_start as duration,
      state,
      wait_event_type,
      wait_event,
      LEFT(query, 100) as query_preview
    FROM pg_stat_activity
    WHERE pid = $target_pid;"
  else
    echo "   Active queries running > 3 seconds:"
    q "SELECT
      pid,
      usename,
      application_name,
      now() - query_start as duration,
      wait_event_type,
      wait_event,
      LEFT(query, 80) as query_preview
    FROM pg_stat_activity
    WHERE state = 'active'
      AND now() - query_start > interval '3 seconds'
    ORDER BY query_start;"
  fi

  # Step 3: Index recommendations
  workflow_step 3 4 "Index Recommendations"

  echo "   Tables with high sequential scans / index scans ratio:"
  q "SELECT
    schemaname || '.' || relname as table_name,
    seq_scan,
    idx_scan,
    CASE WHEN idx_scan > 0 THEN round((100.0 * seq_scan / (seq_scan + idx_scan))::numeric, 2)
         ELSE 100.0 END as seq_scan_pct,
    n_live_tup as rows
  FROM pg_stat_user_tables
  WHERE seq_scan > 100
    AND (idx_scan IS NULL OR seq_scan > idx_scan * 2)
  ORDER BY seq_scan DESC
  LIMIT 10;"

  workflow_result info "Consider adding indexes to tables with high seq_scan%"

  # Step 4: Query plan analysis suggestion
  workflow_step 4 4 "Query Plan Analysis"

  if [ -n "$target_pid" ]; then
    local slow_sql
    slow_sql=$(q_scalar "SELECT query FROM pg_stat_activity WHERE pid = $target_pid;" 2>/dev/null)
    if [ -n "$slow_sql" ]; then
      echo "   SQL for PID $target_pid:"
      echo "   ${slow_sql:0:200}"
      echo ""
      workflow_result info "Analyze with: pg explain \"${slow_sql:0:100}...\""
    fi
  fi

  echo ""
  colorize yellow "💡 Recommendations:"
  echo "   1. Review queries with high total_time in pg_stat_statements"
  echo "   2. Add indexes for frequently scanned tables"
  echo "   3. Use EXPLAIN ANALYZE to understand query plans"
  echo "   4. Consider query rewriting for complex queries"
  echo ""
}

