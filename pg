# Get command parameters variable value
cmd_params_var() {
  local cmd="$1"
  local varname="CMD_PARAMS_${cmd}"
  eval "echo \$$varname"
}

# Check if command supports parameter
cmd_has_param() {
  local cmd="$1" param="$2"
  local params
  params=$(cmd_params_var "$cmd")
  [[ -n "$params" ]] && [[ "$params" == *"$param:"* ]]
}

# Get parameter default value
cmd_param_default() {
  local cmd="$1" param="$2"
  local params
  params=$(cmd_params_var "$cmd")
  [[ -z "$params" ]] && return 1

  local IFS=';'
  local param_defs
  read -ra param_defs <<< "$params"
  for def in "${param_defs[@]}"; do
    local IFS=':'
    local parts
    read -ra parts <<< "$def"
    if [[ "${parts[0]}" == "$param" ]]; then
      echo "${parts[2]}"
      return 0
    fi
  done
  return 1
}

# Show command-specific help
show_cmd_help() {
  local cmd="$1"
  local params
  params=$(cmd_params_var "$cmd")

  echo "Usage: $EXEC_NAME $cmd [options]"
  echo ""

  # Command description based on name
  case "$cmd" in
    ps) echo "Show PostgreSQL process list (active queries)" ;;
    running) echo "Show running queries excluding internal ones" ;;
    blocking) echo "Show blocking and blocked sessions" ;;
    locks) echo "Show lock information" ;;
    slow) echo "Show slow queries from pg_stat_statements" ;;
    top_time) echo "Show top queries by total execution time" ;;
    top_calls) echo "Show top queries by call count" ;;
    top_io) echo "Show top queries by I/O usage" ;;
    table_size) echo "Show table sizes" ;;
    index_size) echo "Show index sizes" ;;
    bloat) echo "Show table bloat estimate" ;;
    unused_indexes) echo "Show unused indexes" ;;
    missing_indexes) echo "Show tables that might need indexes" ;;
    health) echo "Run comprehensive health check" ;;
    *) echo "Command: $cmd" ;;
  esac
  echo ""

  if [[ -n "$params" ]]; then
    echo "Options:"
    local IFS
    IFS=';'
    read -ra param_defs <<< "$params"
    for def in "${param_defs[@]}"; do
      local parts
      # Use bash 3.x compatible IFS handling
      IFS=':' parts=($def)
      local name="${parts[0]}" type="${parts[1]}" default="${parts[2]}" desc="${parts[3]}"

      # Format option name
      local opt_name
      case "$name" in
        limit) opt_name="-n, --limit <num>" ;;
        format) opt_name="-f, --format <type>" ;;
        schema) opt_name="-s, --schema <pattern>" ;;
        min_time) opt_name="-t, --min-time <ms>" ;;
        min_bloat) opt_name="-b, --min-bloat <pct>" ;;
        min_scans) opt_name="--min-scans <num>" ;;
        sections) opt_name="--sections <list>" ;;
        *) opt_name="--$name <value>" ;;
      esac

      printf "  %-25s %s" "$opt_name" "$desc"
      [[ -n "$default" ]] && printf " (default: %s)" "$default"
      [[ "$type" == "choice" ]] && printf " [choices: %s]" "${parts[2]}"
      echo ""
    done
  fi

  echo "  --help                    Show this help message"
  echo ""
  echo "Global Options:"
  echo "  -h, --host <host>         Database host (default: localhost)"
  echo "  -p, --port <port>         Database port (default: 5432)"
  echo "  -u, --user <user>         Database user (default: postgres)"
  echo "  -d, --dbname <name>       Database name (default: postgres)"
  echo ""
}

