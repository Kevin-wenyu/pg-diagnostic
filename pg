# Security Scan
cmd_security_scan()
{
  colorize blue "=== SECURITY SCAN REPORT ==="
  echo ""

  colorize yellow "CONFIGURATION VULNERABILITIES:"

  # Check critical security settings
  q "SELECT name, setting,
       CASE
         WHEN name = 'log_statement' AND setting = 'none' THEN 'HIGH'
         WHEN name = 'log_min_error_statement' AND setting = 'panic' THEN 'MEDIUM'
         WHEN name = 'log_connections' AND setting = 'off' THEN 'LOW'
         WHEN name = 'log_disconnections' AND setting = 'off' THEN 'LOW'
         WHEN name = 'log_lock_waits' AND setting = 'off' THEN 'MEDIUM'
         WHEN name = 'password_encryption' AND setting NOT IN ('scram-sha-256', 'md5') THEN 'HIGH'
         WHEN name = 'log_hostname' AND setting = 'off' THEN 'LOW'
         ELSE 'OK'
       END AS risk_level
     FROM pg_settings
     WHERE name IN ('log_statement', 'log_min_error_statement', 'log_connections',
                    'log_disconnections', 'log_lock_waits', 'password_encryption', 'log_hostname',
                    'tcp_keepalives_idle', 'tcp_keepalives_interval', 'tcp_keepalives_count')
     ORDER BY risk_level DESC NULLS LAST, name;"

  echo ""
  colorize yellow "PRIVILEGE ESCALATION RISKS:"

  q "WITH risky_roles AS (
       SELECT rolname, rolsuper, rolcreatedb, rolcreaterole, rolcanlogin
       FROM pg_roles
       WHERE rolsuper = true OR rolcreaterole = true OR rolcreatedb = true
     )
     SELECT rolname, rolsuper, rolcreatedb, rolcreaterole, rolcanlogin
     FROM risky_roles
     ORDER BY
       (CASE WHEN rolsuper THEN 1 WHEN rolcreaterole THEN 2 WHEN rolcreatedb THEN 3 ELSE 4 END),
       rolname;"
}

