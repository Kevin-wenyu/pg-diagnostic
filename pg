cmd_wal_rate()
{
  local window=${1:-5}

  # Get start LSN
  local start_lsn
  start_lsn=$(q_scalar "SELECT pg_current_wal_lsn();")

  # Wait for the specified window
  echo "Measuring WAL generation rate over ${window} seconds..."
  sleep "$window"

  # Get end LSN and calculate rate
  q "SELECT
       pg_size_pretty(pg_wal_lsn_diff(pg_current_wal_lsn(), '$start_lsn'::pg_lsn)) AS wal_generated,
       pg_wal_lsn_diff(pg_current_wal_lsn(), '$start_lsn'::pg_lsn) AS bytes,
       ROUND(pg_wal_lsn_diff(pg_current_wal_lsn(), '$start_lsn'::pg_lsn) / $window) AS bytes_per_sec,
       pg_size_pretty(ROUND(pg_wal_lsn_diff(pg_current_wal_lsn(), '$start_lsn'::pg_lsn) / $window)) AS rate_per_sec;"
}

cmd_bgwriter()
{
  if [ "${PG_MAJOR_VERSION:-0}" -ge 17 ]; then
    # PostgreSQL 17+ split stats between pg_stat_bgwriter and pg_stat_checkpointer
    q "SELECT
         'buffers_clean' AS metric, buffers_clean::text AS value FROM pg_stat_bgwriter
       UNION ALL SELECT 'maxwritten_clean', maxwritten_clean::text FROM pg_stat_bgwriter
       UNION ALL SELECT 'buffers_alloc', buffers_alloc::text FROM pg_stat_bgwriter
       UNION ALL SELECT 'num_timed', num_timed::text FROM pg_stat_checkpointer
       UNION ALL SELECT 'num_requested', num_requested::text FROM pg_stat_checkpointer
       UNION ALL SELECT 'buffers_written', buffers_written::text FROM pg_stat_checkpointer;"
  else
    q "SELECT checkpoints_timed, checkpoints_req,
         CASE WHEN checkpoints_timed + checkpoints_req > 0
              THEN round(100.0 * checkpoints_timed / (checkpoints_timed + checkpoints_req), 2)
              ELSE 0 END AS timed_ratio,
         buffers_checkpoint, buffers_clean, buffers_backend,
         buffers_alloc,
         pg_size_pretty(buffers_checkpoint*8192) AS checkpoint_bytes,
         pg_size_pretty(buffers_clean*8192) AS clean_bytes,
         pg_size_pretty(buffers_backend*8192) AS backend_bytes,
         pg_size_pretty(buffers_alloc*8192) AS alloc_bytes
       FROM pg_stat_bgwriter;"
  fi
}

