       rows,
       round(CAST(rows AS numeric) / calls, 2) AS rows_per_call,
       round(CAST(${PGS_TOTAL_COL} / NULLIF(shared_blks_hit + shared_blks_read, 0) AS numeric), 2) AS time_per_block_ms
     FROM pg_stat_statements
