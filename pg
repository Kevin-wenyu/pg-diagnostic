# ============================================

cmd_config()
{
  local pattern="${1:-}"

  # Show usage if no pattern provided
  if [ -z "$pattern" ]; then
    colorize blue "=== CONFIGURATION QUERY ==="
    echo ""
    echo "Usage: pg config <parameter>"
    echo "       pg config <pattern>%"
    echo ""
    echo "Examples:"
    echo "  pg config shared_buffers     # Exact match"
    echo "  pg config shared%            # Pattern match"
    echo "  pg config autovacuum         # All autovacuum related"
    echo "  pg config work_mem           # Single parameter with details"
    echo ""
    msg_info "Showing all parameters... (use Ctrl+C to cancel)"
    echo ""
    pattern="%"
  fi

  local sanitized
  sanitized=$(q_sanitize "$pattern")

  colorize blue "=== CONFIGURATION SETTINGS ==="
  echo ""

  # Show exact match first if found
  local exact_match
  exact_match=$(q "SELECT name, setting, unit, source, context, short_desc
     FROM pg_settings
     WHERE name = '$sanitized'
     LIMIT 1;" 2>/dev/null)

  # Count rows in exact match result
  local exact_row_count=0
  exact_row_count=$(echo "$exact_match" | grep -c "|" 2>/dev/null || echo 0)

  if [ "$exact_row_count" -ge 2 ]; then
    colorize green "EXACT MATCH:"
    echo "$exact_match"
    echo ""

    # Show detailed info for exact match
    local detailed
    detailed=$(q "SELECT
       name AS parameter,
       setting AS current_value,
       COALESCE(unit, '') AS unit,
       boot_val AS default_value,
       COALESCE(min_val, '') AS min_value,
       COALESCE(max_val, '') AS max_value,
       category,
       context,
       source,
       CASE WHEN pending_restart THEN 'YES' ELSE 'NO' END AS needs_restart,
       short_desc AS description
     FROM pg_settings
     WHERE name = '$sanitized';" 2>/dev/null)

    if [ -n "$detailed" ]; then
      colorize yellow "DETAILED INFORMATION:"
      echo "$detailed"
      echo ""
    fi
  fi

  # Show all matching parameters
  local all_matches
  all_matches=$(q "SELECT
       name AS parameter,
       setting AS value,
       COALESCE(unit, '') AS unit,
       category,
       context,
       source
     FROM pg_settings
     WHERE name LIKE '%$sanitized%'
     ORDER BY category, name;" 2>/dev/null)

  # Count actual data rows (excluding header and footer)
  local row_count
  row_count=$(echo "$all_matches" | grep -c "|" 2>/dev/null || echo 0)

  # Check if exact match has actual data (check if there's a row with actual values)
  local exact_has_data=false
  local exact_row_count
  exact_row_count=$(echo "$exact_match" | grep -c "|" 2>/dev/null || echo 0)
  if [ "$exact_row_count" -ge 2 ]; then
    exact_has_data=true
  fi

  if [ "$row_count" -gt 2 ] || [ "$exact_has_data" = true ]; then
    # Only show "ALL MATCHING" header if there are more results than just the exact match
    if [ "$exact_has_data" = true ] && [ "$row_count" -gt 3 ]; then
      colorize yellow "ALL MATCHING PARAMETERS:"
    fi
    # Only output if there's data to show (more than just header+footer)
    if [ "$row_count" -ge 2 ]; then
      echo "$all_matches"
    fi
  else
    # Only show warning if no exact match and no pattern matches
    if [ "$exact_has_data" = false ]; then
      msg_warn "No parameters found matching '$pattern'"
      msg_info "Try: pg config shared%"
      msg_info "Try: pg config --help for more examples"
    fi
  fi
}

