q()
{
  local query="$1"
  local result
  local exit_code

  # Validate input - basic check to ensure query is not empty
  if [ -z "$query" ]; then
    echo "Error: Empty query provided" >&2
    return 1
  fi

  # Execute query with timing if DEBUG_QUERIES is set
  if [ "${DEBUG_QUERIES:-0}" = "1" ]; then
    local start_time
    start_time=$(date +%s.%N)
    result=$(echo "$query" | $PSQL_CMD 2>&1)
    local end_time
    end_time=$(date +%s.%N)
    local duration
    duration=$(echo "$end_time - $start_time" | bc -l)
    echo "# Query took: ${duration}s" >&2
    echo "# Query: $query" >&2
  else
    result=$(echo "$query" | $PSQL_CMD 2>&1)
  fi

  exit_code=$?
  if [ $exit_code -ne 0 ]; then
    echo "Error: psql command failed with exit code $exit_code" >&2
    echo "Query: $query" >&2
    echo "Details: $result" >&2
    return $exit_code
  fi
  echo "$result"
}

# JSON output helper - convert table output to JSON
q_json()
{
  local query="$1"
  local result
  result=$(echo "$query" | $PSQL_CMD -t -A -F "|" 2>&1)
  local exit_code=$?
  if [ "$exit_code" -ne 0 ]; then
    echo "Error: Query failed" >&2
    return "$exit_code"
  fi
  # Simple JSON conversion (header + rows)
  echo "{"
  echo "  \"query\": \"$query\","
  echo "  \"result\": \"$result\""
  echo "}"
}

# Scalar value query - returns single value without headers
# Use for queries that return a single numeric/text value for use in arithmetic
q_scalar()
{
  local query="$1"
  local result

  # Execute with -t (tuples only) and -A (unaligned) to get just the value
  result=$(echo "$query" | $PSQL_CMD -t -A 2>&1)
  local exit_code=$?

  if [ $exit_code -ne 0 ]; then
    return $exit_code
  fi

  # Trim whitespace and return
  echo "$result" | tr -d '[:space:]'
}

q_sanitize()
{
  local input="$1"
  # First, remove any null bytes which could be used in some injection attacks
  input=$(printf '%s' "$input" | tr -d '\000')

  # Remove any potentially dangerous characters
  # Allow only alphanumeric characters, underscore, space, dot, dash, colon, and percent signs (for LIKE patterns)
  local sanitized
  sanitized=$(printf '%s' "$input" | sed 's/[^a-zA-Z0-9_ .:%-]/_/g')

  # Escape single quotes by doubling them (PostgreSQL's SQL string escape mechanism)
  sanitized=$(printf '%s' "$sanitized" | sed "s/'/''/g")

  # Additional protection: ensure the input doesn't contain SQL keywords or dangerous patterns
  # Convert to lowercase for comparison but preserve original case in output
  local lower_input
  lower_input=$(printf '%s' "$sanitized" | tr '[:upper:]' '[:lower:]')

  # Check for potentially dangerous patterns
  if [[ "$lower_input" =~ (drop|truncate|delete|insert|update|exec|execute|alter|create|merge|replace|grant|revoke|commit|rollback|begin|transaction|union|select\b.*\bfrom|order\s+by|group\s+by|having|limit|offset|join|into|values|where) ]]; then
    # If dangerous patterns are detected, strip them out
    sanitized=$(printf '%s' "$sanitized" | sed 's/[;,]//g')  # Remove potential statement terminators
    sanitized=$(printf '%s' "$sanitized" | sed 's/[-]{2,}//g')  # Remove comment indicators
    sanitized=$(printf '%s' "$sanitized" | sed 's/[\/][*].*[*][/][ \t\n\r\f]*/ /g')  # Remove /* */ style comments
  fi

  echo "$sanitized"
}

