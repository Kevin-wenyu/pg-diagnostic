# Activity queries
readonly SQL_ACTIVITY_ACTIVE="SELECT pid, usename, application_name, client_addr::text, state,
       now()-query_start AS duration,
       wait_event_type, wait_event, LEFT(query, 80) AS query
     FROM pg_stat_activity
     WHERE state = 'active'
     ORDER BY query_start DESC
     LIMIT %s"
readonly SQL_ACTIVITY_RUNNING="SELECT pid, usename, application_name,
       now()-query_start AS duration,
       wait_event_type, wait_event,
       LEFT(query, 120) AS query
     FROM pg_stat_activity
     WHERE state = 'active' AND query NOT LIKE '%%pg_stat_activity%%'
     ORDER BY query_start LIMIT %s"

# Blocking and lock queries
readonly SQL_BLOCKING_EXISTS="SELECT count(*) FROM pg_locks bl1
    JOIN pg_locks bl2 ON bl1.locktype = bl2.locktype
      AND bl1.database IS NOT DISTINCT FROM bl2.database
      AND bl1.relation IS NOT DISTINCT FROM bl2.relation
      AND bl1.page IS NOT DISTINCT FROM bl2.page
      AND bl1.tuple IS NOT DISTINCT FROM bl2.tuple
      AND bl1.virtualxid IS NOT DISTINCT FROM bl2.virtualxid
      AND bl1.transactionid IS NOT DISTINCT FROM bl2.transactionid
      AND bl1.classid IS NOT DISTINCT FROM bl2.classid
      AND bl1.objid IS NOT DISTINCT FROM bl2.objid
      AND bl1.objsubid IS NOT DISTINCT FROM bl2.objsubid
      AND bl1.pid != bl2.pid
      AND NOT bl1.granted AND bl2.granted"
# shellcheck disable=SC2034
readonly SQL_BLOCKING_CHAIN="SELECT
    bl.pid AS blocked_pid,
    bl.usename AS blocked_user,
    bl.application_name AS blocked_app,
    bl.client_addr::text AS blocked_client,
    bl.query AS blocked_query,
    kl.pid AS blocking_pid,
    kl.usename AS blocking_user,
    kl.application_name AS blocking_app,
    kl.query AS blocking_query,
    bl.wait_event_type,
    bl.wait_event
FROM pg_stat_activity bl
JOIN pg_locks bl1 ON bl.pid = bl1.pid AND NOT bl1.granted
JOIN pg_locks kl1 ON bl1.locktype = kl1.locktype
    AND bl1.database IS NOT DISTINCT FROM kl1.database
    AND bl1.relation IS NOT DISTINCT FROM kl1.relation
    AND bl1.page IS NOT DISTINCT FROM kl1.page
    AND bl1.tuple IS NOT DISTINCT FROM kl1.tuple
    AND bl1.virtualxid IS NOT DISTINCT FROM kl1.virtualxid
    AND bl1.transactionid IS NOT DISTINCT FROM kl1.transactionid
    AND bl1.classid IS NOT DISTINCT FROM kl1.classid
    AND bl1.objid IS NOT DISTINCT FROM kl1.objid
    AND bl1.objsubid IS NOT DISTINCT FROM kl1.objsubid
    AND kl1.granted
JOIN pg_stat_activity kl ON kl1.pid = kl.pid
WHERE bl.pid != kl.pid
ORDER BY bl.query_start
LIMIT %s"

# Table and index size queries
# shellcheck disable=SC2034
readonly SQL_TABLE_SIZE="SELECT schemaname, tablename,
    pg_size_pretty(pg_total_relation_size(schemaname||'.'||tablename)) AS total_size,
    pg_total_relation_size(schemaname||'.'||tablename) AS size_bytes
FROM pg_tables
WHERE schemaname NOT IN ('pg_catalog', 'information_schema')
ORDER BY size_bytes DESC LIMIT %s"
readonly SQL_INDEX_SIZE="SELECT schemaname, relname AS tablename, indexrelname AS indexname,
    pg_size_pretty(pg_relation_size(indexrelid)) AS index_size
FROM pg_stat_user_indexes
ORDER BY pg_relation_size(indexrelid) DESC LIMIT %s"

# Connection and session queries
# shellcheck disable=SC2034
readonly SQL_CONNECTION_STATS="SELECT state, count(*) AS count,
    round(100.0 * count(*) / sum(count(*)) OVER (), 2) AS percentage
FROM pg_stat_activity
GROUP BY state ORDER BY count DESC"
readonly SQL_CONNECTION_LIMITS="SELECT 'max_connections' AS setting, setting AS value FROM pg_settings WHERE name = 'max_connections'
UNION ALL
SELECT 'reserved_superuser', setting FROM pg_settings WHERE name = 'superuser_reserved_connections'"

# Replication queries
# shellcheck disable=SC2034
readonly SQL_REPLICATION_STATUS="SELECT client_addr, application_name, state, sync_state,
    pg_size_pretty(pg_wal_lsn_diff(sent_lsn, write_lsn)) AS write_lag,
    pg_size_pretty(pg_wal_lsn_diff(sent_lsn, flush_lsn)) AS flush_lag
FROM pg_stat_replication"
readonly SQL_REPLICATION_SLOTS="SELECT slot_name, slot_type, active, active_pid,
    pg_size_pretty(pg_wal_lsn_diff(pg_current_wal_lsn(), restart_lsn)) AS lag,
    safe_wal_size, wal_status
FROM pg_replication_slots ORDER BY active DESC"
readonly SQL_REPLICATION_SLOT_LAG="SELECT slot_name, slot_type, active,
    pg_size_pretty(pg_wal_lsn_diff(pg_current_wal_lsn(), restart_lsn)) AS lag,
    pg_wal_lsn_diff(pg_current_wal_lsn(), restart_lsn) AS lag_bytes,
    restart_lsn,
    pg_current_wal_lsn() AS current_lsn,
    wal_status,
    safe_wal_size
FROM pg_replication_slots
ORDER BY lag_bytes DESC"

# Performance queries
# shellcheck disable=SC2034
readonly SQL_CACHE_HIT="SELECT
    'index hit rate' AS name,
    CASE WHEN sum(heap_blks_hit) + sum(heap_blks_read) = 0
        THEN 0
        ELSE round(100.0 * sum(heap_blks_hit) / (sum(heap_blks_hit) + sum(heap_blks_read)), 2)
    END AS ratio
FROM pg_statio_user_tables
UNION ALL
SELECT
    'cache hit rate',
    CASE WHEN sum(heap_blks_hit) + sum(heap_blks_read) = 0
        THEN 0
        ELSE round(100.0 * sum(heap_blks_hit) / (sum(heap_blks_hit) + sum(heap_blks_read)), 2)
    END
FROM pg_statio_user_tables"

