cmd_report()
{
  local report_type="${1:-health}"
  local output_format="${2:-text}"
  local output_file=""

  # Parse arguments
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --format) output_format="$2"; shift 2 ;;
      --output|-o) output_file="$2"; shift 2 ;;
      html|markdown|md|json) output_format="$1"; shift ;;
      health|performance|full) report_type="$1"; shift ;;
      *) shift ;;
    esac
  done

  case "$report_type" in
    health) report_health "$output_format" "$output_file" ;;
    performance) report_performance "$output_format" "$output_file" ;;
    full) report_full "$output_format" "$output_file" ;;
    *)
      echo "Usage: $EXEC_NAME report [type] [options]"
      echo ""
      echo "Types:"
      echo "  health          Health check report (default)"
      echo "  performance     Performance analysis report"
      echo "  full            Complete comprehensive report"
      echo ""
      echo "Options:"
      echo "  --format <fmt>  Output format: text, html, markdown, json"
      echo "  --output <file> Save to file"
      echo ""
      echo "Examples:"
      echo "  $EXEC_NAME report health"
      echo "  $EXEC_NAME report performance --format html --output report.html"
      echo "  $EXEC_NAME report full --format markdown"
      ;;
  esac
