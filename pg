  echo ""
  colorize yellow "💡 Recommendations:"
  echo "   1. Increase shared_buffers if cache hit ratio < 95%"
  echo "   2. Review tables with high sequential I/O"
  echo "   3. Consider faster storage (SSD) for high I/O workloads"
  echo "   4. Optimize queries to reduce I/O operations"
  echo ""
}

