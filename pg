# ============================================
# MONITOR - REAL-TIME MONITORING
# ============================================

cmd_monitor()
{
  local action="${1:-status}"
  shift || true

  case "$action" in
    start)    monitor_start "$@" ;;
    stop)     monitor_stop ;;
    status)   monitor_status ;;
    log)      monitor_log ;;
    alert)    monitor_alert ;;
    watch)    monitor_watch "$@" ;;
    *)
      echo "Usage: $EXEC_NAME monitor <action> [options]"
      echo ""
      echo "Actions:"
      echo "  start [interval]  Start monitoring (default: 60s)"
      echo "  stop              Stop monitoring"
      echo "  status            Show monitoring status"
      echo "  log               Show recent monitor log"
      echo "  alert             Show alert history"
      echo "  watch <metric>    Watch specific metric"
      echo ""
      echo "Examples:"
      echo "  $EXEC_NAME monitor start 30       # Monitor every 30 seconds"
      echo "  $EXEC_NAME monitor status"
      echo "  $EXEC_NAME monitor watch connections"
      ;;
  esac
}

monitor_start()
{
  local interval="${1:-60}"
  local monitor_pid_file="${HOME}/.pg_monitor.pid"
  local monitor_log="${HOME}/.pg_monitor.log"

  if [ -f "$monitor_pid_file" ]; then
    local pid
    pid=$(cat "$monitor_pid_file" 2>/dev/null)
    if kill -0 "$pid" 2>/dev/null; then
      echo "Monitor already running (PID: $pid)"
      return 1
    fi
  fi

  echo "Starting PostgreSQL monitor (interval: ${interval}s)..."
  echo "Log file: $monitor_log"

  # Start background monitoring
  (
    while true; do
      monitor_check >> "$monitor_log" 2>&1
      sleep "$interval"
    done
  ) &

  echo $! > "$monitor_pid_file"
  echo "Monitor started with PID: $(cat "$monitor_pid_file")"
  echo ""
  echo "Check status: pg monitor status"
  echo "View log: pg monitor log"
  echo "Stop: pg monitor stop"
}

monitor_stop()
{
  local monitor_pid_file="${HOME}/.pg_monitor.pid"

  if [ -f "$monitor_pid_file" ]; then
    local pid
    pid=$(cat "$monitor_pid_file" 2>/dev/null)
    if kill -0 "$pid" 2>/dev/null; then
      kill "$pid" 2>/dev/null
      rm -f "$monitor_pid_file"
      echo "Monitor stopped"
    else
      echo "Monitor not running"
      rm -f "$monitor_pid_file"
    fi
  else
    echo "Monitor not running"
  fi
}

monitor_status()
{
  local monitor_pid_file="${HOME}/.pg_monitor.pid"
  local monitor_log="${HOME}/.pg_monitor.log"

  echo ""
  echo "╔════════════════════════════════════════════════════════════════╗"
  echo "║          📊 MONITOR STATUS                                      ║"
  echo "╚════════════════════════════════════════════════════════════════╝"
  echo ""

  if [ -f "$monitor_pid_file" ]; then
    local pid
    pid=$(cat "$monitor_pid_file" 2>/dev/null)
    if kill -0 "$pid" 2>/dev/null; then
      colorize green "   ✅ Monitor is RUNNING (PID: $pid)"
    else
      colorize red "   ❌ Monitor is STOPPED"
    fi
  else
    colorize red "   ❌ Monitor is STOPPED"
  fi

  if [ -f "$monitor_log" ]; then
    # shellcheck disable=SC2012
    local log_size
    log_size=$(ls -lh "$monitor_log" 2>/dev/null | awk '{print $5}')
    echo "   Log file: $monitor_log ($log_size)"
    echo "   Log entries: $(wc -l < "$monitor_log" 2>/dev/null)"
  fi

  echo ""
}

monitor_check()
{
  local timestamp
  timestamp=$(date '+%Y-%m-%d %H:%M:%S')

  # Check connections
  local conn_count max_conn conn_pct
  conn_count=$(q_scalar "SELECT count(*) FROM pg_stat_activity;" 2>/dev/null || echo 0)
  max_conn=$(q_scalar "SELECT setting::int FROM pg_settings WHERE name = 'max_connections';" 2>/dev/null || echo 100)

  if [[ "$conn_count" =~ ^[0-9]+$ ]] && [[ "$max_conn" =~ ^[0-9]+$ ]] && [ "$max_conn" -gt 0 ]; then
    conn_pct=$(( conn_count * 100 / max_conn ))

    if [ "$conn_pct" -gt 90 ]; then
      echo "[$timestamp] ALERT: Connection usage CRITICAL - $conn_pct% ($conn_count/$max_conn)"
    elif [ "$conn_pct" -gt 75 ]; then
      echo "[$timestamp] WARNING: Connection usage HIGH - $conn_pct% ($conn_count/$max_conn)"
    fi
  fi

  # Check blocking
  local blocked_count
  blocked_count=$(q_scalar "SELECT count(*) FROM pg_locks WHERE NOT granted;" 2>/dev/null || echo 0)
  if [ "$blocked_count" -gt 0 ]; then
    echo "[$timestamp] ALERT: $blocked_count blocked sessions detected"
  fi

  # Check slow queries
  local slow_count
  slow_count=$(q_scalar "SELECT count(*) FROM pg_stat_activity WHERE state = 'active' AND now() - query_start > interval '30 seconds';" 2>/dev/null || echo 0)
  if [ "$slow_count" -gt 0 ]; then
    echo "[$timestamp] WARNING: $slow_count slow queries (>30s)"
  fi

  # Periodic status (every 10 checks - roughly)
  if [ "$(date +%s)" -gt "${LAST_STATUS_CHECK:-0}" ]; then
    echo "[$timestamp] STATUS: Connections=$conn_count, Blocked=$blocked_count, Slow=$slow_count"
    LAST_STATUS_CHECK=$(($(date +%s) + 600))  # Next status in 10 minutes
  fi
}

monitor_log()
{
  local monitor_log="${HOME}/.pg_monitor.log"
  local lines="${1:-50}"

  if [ -f "$monitor_log" ]; then
    echo "Recent monitor log entries (last $lines lines):"
    echo ""
    tail -n "$lines" "$monitor_log"
  else
    echo "No monitor log found"
  fi
}

monitor_alert()
{
  local monitor_log="${HOME}/.pg_monitor.log"

  if [ -f "$monitor_log" ]; then
    echo "Alert history:"
    echo ""
    grep -E "ALERT|WARNING" "$monitor_log" | tail -20
  else
    echo "No alert history found"
  fi
}

monitor_watch()
{
  local metric="${1:-connections}"
  local interval="${2:-5}"

  echo "Watching $metric every ${interval}s (Press Ctrl+C to stop)..."
  echo ""

  while true; do
    clear
    echo "╔════════════════════════════════════════════════════════════════╗"
    echo "║          👀 REAL-TIME MONITOR: $metric"
    echo "╚════════════════════════════════════════════════════════════════╝"
    echo ""
    echo "Time: $(date '+%Y-%m-%d %H:%M:%S')"
    echo ""

    case "$metric" in
      conn|connections)
        q "SELECT
          count(*) as total,
          count(*) FILTER (WHERE state = 'active') as active,
          count(*) FILTER (WHERE state = 'idle') as idle,
          count(*) FILTER (WHERE state = 'idle in transaction') as idle_in_tx
        FROM pg_stat_activity;"
        ;;
      slow)
        q "SELECT
          pid,
          usename,
          now() - query_start as duration,
          LEFT(query, 60) as query_preview
        FROM pg_stat_activity
        WHERE state = 'active'
          AND now() - query_start > interval '1 second'
        ORDER BY query_start;"
        ;;
      locks|blocking)
        q "SELECT
          pid,
          mode,
          granted,
          relation::regclass as table_name
        FROM pg_locks
        WHERE relation IS NOT NULL
        LIMIT 20;"
        ;;
      cache)
        q "SELECT
          datname,
          round((100.0 * blks_hit / nullif(blks_hit + blks_read, 0))::numeric, 2) as hit_ratio
        FROM pg_stat_database
        WHERE datname NOT IN ('template0', 'template1');"
        ;;
      *)
        echo "Unknown metric: $metric"
        echo "Available: connections, slow, locks, cache"
        return 1
        ;;
    esac

    echo ""
    echo "Refreshing in ${interval}s..."
    sleep "$interval"
  done
}

# ============================================
# DIAGNOSTIC FUNCTIONS
# ============================================

cmd_diagnose_performance()
{
  echo "╔════════════════════════════════════════════════════════════════╗"
  echo "║           PERFORMANCE DIAGNOSIS REPORT                          ║"
  echo "╚════════════════════════════════════════════════════════════════╝"
  echo ""
  echo "Generated at: $(date '+%Y-%m-%d %H:%M:%S')"
  echo "Database: $DBNAME @ $DBHOST:$DBPORT"
  echo ""

  local issues=0

  # Section 1: Cache Performance
  colorize yellow "═══ CACHE PERFORMANCE ═══"
  echo ""

  local cache_ratio
  cache_ratio=$(q_scalar "SELECT round(100.0 * sum(blks_hit) / nullif(sum(blks_hit) + sum(blks_read), 0), 2)
    FROM pg_stat_database WHERE datname not in ('template0', 'template1');" 2>/dev/null)

  if [ -n "$cache_ratio" ] && [[ "$cache_ratio" =~ ^[0-9]+\.?[0-9]*$ ]]; then
    echo "Cache hit ratio: ${cache_ratio}%"
    if (( $(echo "${cache_ratio} < 90" | bc -l) )); then
      colorize red "CRITICAL: Cache hit ratio < 90% - Consider increasing shared_buffers"
      issues=$((issues + 1))
    elif (( $(echo "${cache_ratio} < 95" | bc -l) )); then
      colorize yellow "WARNING: Cache hit ratio < 95%"
      issues=$((issues + 1))
    else
      colorize green "OK: Cache performance excellent"
    fi
  else
    echo "Cache hit ratio: Unable to determine"
  fi
  echo ""

  # Section 2: Index Usage
  colorize yellow "═══ INDEX USAGE ANALYSIS ═══"
  echo ""

  local seq_scan_ratio
  seq_scan_ratio=$(q_scalar "SELECT round(100.0 * sum(seq_scan) / nullif(sum(seq_scan) + sum(idx_scan), 0), 2)
    FROM pg_stat_user_tables WHERE n_live_tup > 1000;" 2>/dev/null)

  if [ -n "$seq_scan_ratio" ] && [[ "$seq_scan_ratio" =~ ^[0-9]+\.?[0-9]*$ ]]; then
    echo "Sequential scan ratio: ${seq_scan_ratio}%"
    if (( $(echo "${seq_scan_ratio} > 50" | bc -l) )); then
      colorize red "CRITICAL: High sequential scan ratio - Missing indexes detected"
      issues=$((issues + 1))
    elif (( $(echo "${seq_scan_ratio} > 20" | bc -l) )); then
      colorize yellow "WARNING: Moderate sequential scan ratio"
      issues=$((issues + 1))
    else
      colorize green "OK: Index usage healthy"
    fi
  fi
  echo ""

  # Section 3: Slow Queries
  colorize yellow "═══ SLOW QUERY ANALYSIS ═══"
  echo ""

  local slow_count
  slow_count=$(q_scalar "SELECT count(*) FROM pg_stat_activity
    WHERE state = 'active' AND query_start < now() - interval '5 seconds';" 2>/dev/null || echo 0)

  echo "Active queries > 5s: $slow_count"
  if [[ "$slow_count" =~ ^[0-9]+$ ]]; then
    if [ "$slow_count" -gt 10 ]; then
      colorize red "CRITICAL: $slow_count slow queries running"
      issues=$((issues + 1))
    elif [ "$slow_count" -gt 5 ]; then
      colorize yellow "WARNING: $slow_count slow queries running"
      issues=$((issues + 1))
    else
      colorize green "OK: Query performance acceptable"
    fi
  fi
  echo ""

  # Section 4: I/O Statistics
  colorize yellow "═══ I/O PERFORMANCE ═══"
  echo ""

  if [ "$PG_MAJOR_VERSION" -ge 16 ] && [ -n "$HAS_PG_STAT_IO" ]; then
    local io_stats
    io_stats=$(q "SELECT backend_type, object, reads, writes FROM pg_stat_io ORDER BY reads DESC LIMIT 5;" 2>/dev/null)
    if [ -n "$io_stats" ]; then
      echo "Top I/O by backend:"
      echo "$io_stats"
    fi
  else
    echo "I/O stats (database level):"
    q "SELECT datname, blks_read, blks_hit,
         round(100.0 * blks_hit / nullif(blks_hit + blks_read, 0), 2) as hit_pct
       FROM pg_stat_database WHERE datname = current_database();" 2>/dev/null
  fi
  echo ""

  # Summary
  colorize yellow "═══ PERFORMANCE SUMMARY ═══"
  echo ""
  if [ "$issues" -eq 0 ]; then
    colorize green "Performance Status: EXCELLENT - No issues detected"
  else
    colorize yellow "Performance Status: $issues issue(s) detected"
    echo ""
    echo "Recommendations:"
    [ "$cache_ratio" -lt 90 ] 2>/dev/null && echo "  - Increase shared_buffers for better caching"
    echo "  - Run 'pg top_time' to identify slow queries"
    echo "  - Run 'pg missing_indexes' to find missing indexes"
    echo "  - Check 'pg wait_events' for bottlenecks"
  fi
  echo ""
}

cmd_diagnose_connection()
{
  echo "╔════════════════════════════════════════════════════════════════╗"
  echo "║           CONNECTION DIAGNOSIS REPORT                           ║"
  echo "╚════════════════════════════════════════════════════════════════╝"
  echo ""
  echo "Generated at: $(date '+%Y-%m-%d %H:%M:%S')"
  echo "Database: $DBNAME @ $DBHOST:$DBPORT"
  echo ""

  local issues=0

  # Section 1: Connection Pool Status
  colorize yellow "═══ CONNECTION POOL STATUS ═══"
  echo ""

  local current_conn max_conn conn_pct
  current_conn=$(q_scalar "SELECT count(*) FROM pg_stat_activity;" 2>/dev/null || echo 0)
  max_conn=$(q_scalar "SELECT setting::int FROM pg_settings WHERE name = 'max_connections';" 2>/dev/null || echo 100)

  if [[ "$current_conn" =~ ^[0-9]+$ ]] && [[ "$max_conn" =~ ^[0-9]+$ ]] && [ "$max_conn" -gt 0 ]; then
    conn_pct=$(( current_conn * 100 / max_conn ))
    echo "Current connections: $current_conn / $max_conn ($conn_pct%)"

    if [ "$conn_pct" -gt 90 ]; then
      colorize red "CRITICAL: Connection pool nearly exhausted (>90%)"
      issues=$((issues + 1))
    elif [ "$conn_pct" -gt 75 ]; then
      colorize yellow "WARNING: High connection usage (>75%)"
      issues=$((issues + 1))
    else
      colorize green "OK: Connection usage healthy"
    fi
  fi
  echo ""

  # Section 2: Connection States
  colorize yellow "═══ CONNECTION STATES ═══"
  echo ""

  q "SELECT state, count(*) as count,
       round(100.0 * count(*) / sum(count(*)) over(), 2) as percentage
     FROM pg_stat_activity WHERE state IS NOT NULL GROUP BY state ORDER BY count DESC;" 2>/dev/null
  echo ""

  # Section 3: Idle in Transaction
  colorize yellow "═══ IDLE IN TRANSACTION ANALYSIS ═══"
  echo ""

  local idle_count idle_max
  idle_count=$(q_scalar "SELECT count(*) FROM pg_stat_activity WHERE state = 'idle in transaction';" 2>/dev/null || echo 0)
  idle_max=$(q_scalar "SELECT COALESCE(max(EXTRACT(EPOCH FROM (now() - xact_start))), 0)
    FROM pg_stat_activity WHERE state = 'idle in transaction';" 2>/dev/null || echo 0)

  echo "Idle in transaction: $idle_count sessions"
  echo "Max idle duration: ${idle_max}s"

  if [[ "$idle_count" =~ ^[0-9]+$ ]]; then
    if [ "$idle_count" -gt 10 ]; then
      colorize red "CRITICAL: $idle_count sessions idle in transaction"
      issues=$((issues + 1))
    elif [ "$idle_count" -gt 5 ]; then
      colorize yellow "WARNING: $idle_count sessions idle in transaction"
      issues=$((issues + 1))
    else
      colorize green "OK: Idle transactions under control"
    fi
  fi

  if [[ "$idle_max" =~ ^[0-9]+\.?[0-9]*$ ]]; then
    if (( $(echo "$idle_max > 300" | bc -l) )); then
      colorize red "CRITICAL: Long-running idle transaction detected (>5min)"
      issues=$((issues + 1))
    fi
  fi
  echo ""

  # Section 4: Connection by Application
  colorize yellow "═══ TOP CONNECTIONS BY APPLICATION ═══"
  echo ""

  q "SELECT application_name, count(*) as connections,
       count(*) FILTER(WHERE state = 'active') as active
     FROM pg_stat_activity
     WHERE application_name IS NOT NULL AND application_name != ''
     GROUP BY application_name ORDER BY connections DESC LIMIT 10;" 2>/dev/null
  echo ""

  # Summary
  colorize yellow "═══ CONNECTION SUMMARY ═══"
  echo ""
  if [ "$issues" -eq 0 ]; then
    colorize green "Connection Status: HEALTHY - No issues detected"
  else
    colorize yellow "Connection Status: $issues issue(s) detected"
    echo ""
    echo "Recommendations:"
    echo "  - Consider implementing connection pooling (PgBouncer)"
    echo "  - Review idle_in_transaction_session_timeout setting"
    echo "  - Check application connection leak patterns"
    echo "  - Run 'pg ps' to see active connections"
  fi
  echo ""
}

cmd_diagnose_replication()
{
  echo "╔════════════════════════════════════════════════════════════════╗"
  echo "║           REPLICATION DIAGNOSIS REPORT                          ║"
  echo "╚════════════════════════════════════════════════════════════════╝"
  echo ""
  echo "Generated at: $(date '+%Y-%m-%d %H:%M:%S')"
  echo "Database: $DBNAME @ $DBHOST:$DBPORT"
  echo ""

  local issues=0

  # Check if replication is configured
  local repl_count
  repl_count=$(q_scalar "SELECT count(*) FROM pg_stat_replication;" 2>/dev/null || echo 0)

  if [ "$repl_count" -eq 0 ]; then
    colorize yellow "WARNING: No active replication detected"
    echo ""
    echo "This may mean:"
    echo "  - This is a standby server (check pg_is_in_recovery)"
    echo "  - Replication is not configured"
    echo "  - All replicas are disconnected"
    echo ""

    local in_recovery
    in_recovery=$(q_scalar "SELECT pg_is_in_recovery();" 2>/dev/null)
    if [ "$in_recovery" = "t" ]; then
      colorize green "Note: This server is in recovery mode (standby)"
    fi
    return 0
  fi

  # Section 1: Replication Status
  colorize yellow "═══ REPLICATION STATUS ═══"
  echo ""
  echo "Active replicas: $repl_count"
  echo ""

  q "SELECT client_addr, application_name, state, sync_state,
       pg_size_pretty(pg_wal_lsn_diff(pg_current_wal_lsn(), sent_lsn)) as sent_lag,
       pg_size_pretty(pg_wal_lsn_diff(sent_lsn, write_lsn)) as write_lag,
       pg_size_pretty(pg_wal_lsn_diff(write_lsn, flush_lsn)) as flush_lag,
       pg_size_pretty(pg_wal_lsn_diff(flush_lsn, replay_lsn)) as replay_lag
     FROM pg_stat_replication;" 2>/dev/null
  echo ""

  # Section 2: Replication Lag
  colorize yellow "═══ REPLICATION LAG ANALYSIS ═══"
  echo ""

  local max_lag_bytes
  max_lag_bytes=$(q_scalar "SELECT COALESCE(max(pg_wal_lsn_diff(pg_current_wal_lsn(), replay_lsn)), 0)
    FROM pg_stat_replication;" 2>/dev/null || echo 0)

  echo "Max replication lag: $(echo "$max_lag_bytes" | numfmt --to=iec 2>/dev/null || echo "${max_lag_bytes} bytes")"

  if [[ "$max_lag_bytes" =~ ^[0-9]+$ ]]; then
    if [ "$max_lag_bytes" -gt 1073741824 ]; then  # 1GB
      colorize red "CRITICAL: Replication lag > 1GB"
      issues=$((issues + 1))
    elif [ "$max_lag_bytes" -gt 104857600 ]; then  # 100MB
      colorize yellow "WARNING: Replication lag > 100MB"
      issues=$((issues + 1))
    else
      colorize green "OK: Replication lag acceptable"
    fi
  fi
  echo ""

  # Section 3: Replication Slots
  colorize yellow "═══ REPLICATION SLOTS ═══"
  echo ""

  q "SELECT slot_name, slot_type, active, active_pid,
       pg_size_pretty(pg_wal_lsn_diff(pg_current_wal_lsn(), restart_lsn)) as retained_wal,
       wal_status
     FROM pg_replication_slots ORDER BY active DESC;" 2>/dev/null
  echo ""

  # Section 4: Slot Issues
  local inactive_slots
  inactive_slots=$(q_scalar "SELECT count(*) FROM pg_replication_slots WHERE NOT active;" 2>/dev/null || echo 0)

  if [[ "$inactive_slots" =~ ^[0-9]+$ ]] && [ "$inactive_slots" -gt 0 ]; then
    colorize yellow "WARNING: $inactive_slots inactive replication slot(s) - May retain WAL files"
    issues=$((issues + 1))
  fi
  echo ""

  # Summary
  colorize yellow "═══ REPLICATION SUMMARY ═══"
  echo ""
  if [ "$issues" -eq 0 ]; then
    colorize green "Replication Status: HEALTHY - All replicas performing well"
  else
    colorize yellow "Replication Status: $issues issue(s) detected"
    echo ""
    echo "Recommendations:"
    echo "  - Check network latency between primary and replicas"
    echo "  - Monitor disk space on primary (WAL retention)"
    echo "  - Review max_wal_size and checkpoint settings"
    echo "  - Clean up inactive replication slots if no longer needed"
  fi
  echo ""
}

cmd_diagnose_slow_query()
{
  local target_pid="$1"

  echo "╔════════════════════════════════════════════════════════════════╗"
  echo "║           SLOW QUERY DIAGNOSIS REPORT                           ║"
  echo "╚════════════════════════════════════════════════════════════════╝"
  echo ""
  echo "Generated at: $(date '+%Y-%m-%d %H:%M:%S')"
  echo "Database: $DBNAME @ $DBHOST:$DBPORT"
  echo ""

  if [ -n "$target_pid" ]; then
    echo "Target PID: $target_pid"
    echo ""

    # Analyze specific query
    colorize yellow "═══ QUERY ANALYSIS FOR PID $target_pid ═══"
    echo ""

    q "SELECT pid, usename, application_name, client_addr::text,
         state, wait_event_type, wait_event,
         now() - query_start as duration,
         LEFT(query, 200) as query
       FROM pg_stat_activity WHERE pid = $target_pid;" 2>/dev/null
    echo ""

    # Check for blocking
    colorize yellow "═══ BLOCKING ANALYSIS ═══"
    echo ""

    local blocked_by
    blocked_by=$(q "SELECT pg_blocking_pids($target_pid);" 2>/dev/null)
    if [ -n "$blocked_by" ] && [ "$blocked_by" != "{}" ]; then
      colorize yellow "This query is blocked by: $blocked_by"
      echo ""
      q "SELECT pid, usename, state, LEFT(query, 100) as query
         FROM pg_stat_activity WHERE pid = ANY(pg_blocking_pids($target_pid));" 2>/dev/null
    else
      colorize green "No blocking detected for this query"
    fi
    echo ""
  else
    # No specific PID, show overall slow query analysis
    colorize yellow "═══ CURRENT SLOW QUERIES ═══"
    echo ""

    q "SELECT pid, usename, application_name,
         now() - query_start as duration,
         wait_event_type, wait_event,
         LEFT(query, 150) as query
       FROM pg_stat_activity
       WHERE state = 'active' AND query_start < now() - interval '5 seconds'
       ORDER BY query_start LIMIT 10;" 2>/dev/null
    echo ""
  fi

  # Section 2: pg_stat_statements Analysis (if available)
  if extension_installed "pg_stat_statements" >/dev/null; then
    colorize yellow "═══ HISTORICAL SLOW QUERY ANALYSIS ═══"
    echo ""

    init_pg_stat_statements_columns

    q "SELECT queryid, LEFT(query, 80) as query,
         calls, round($PGS_TOTAL_COL::numeric, 2) as total_time,
         round(($PGS_TOTAL_COL / calls)::numeric, 2) as mean_time,
         round($PGS_MAX_COL::numeric, 2) as max_time
       FROM pg_stat_statements
       WHERE calls > 10 AND $PGS_MEAN_COL > 100
       ORDER BY $PGS_MEAN_COL DESC LIMIT 10;" 2>/dev/null
    echo ""

    # Top I/O queries
    colorize yellow "═══ TOP I/O QUERIES ═══"
    echo ""

    if [ "$PG_MAJOR_VERSION" -ge 13 ]; then
      q "SELECT LEFT(query, 60) as query, calls,
           shared_blks_hit + shared_blks_read as blocks,
           round(100.0 * shared_blks_hit / nullif(shared_blks_hit + shared_blks_read, 0), 2) as hit_rate
         FROM pg_stat_statements
         WHERE calls > 10
         ORDER BY (shared_blks_hit + shared_blks_read) DESC LIMIT 10;" 2>/dev/null
    fi
    echo ""
  fi

  # Section 3: Wait Events
  colorize yellow "═══ CURRENT WAIT EVENTS ═══"
  echo ""

  q "SELECT wait_event_type, wait_event, count(*) as count
    FROM pg_stat_activity
    WHERE wait_event IS NOT NULL
    GROUP BY wait_event_type, wait_event
    ORDER BY count DESC LIMIT 10;" 2>/dev/null
  echo ""

  # Summary
  colorize yellow "═══ SLOW QUERY SUMMARY ═══"
  echo ""
  echo "Recommendations:"
  echo "  - Run 'pg explain <query>' to analyze query plans"
  echo "  - Check 'pg missing_indexes' for missing indexes"
  echo "  - Review 'pg top_time' for consistently slow queries"
  echo "  - Monitor wait_events for resource contention"
  echo ""
}

cmd_diagnose_lock_issue()
{
  echo "╔════════════════════════════════════════════════════════════════╗"
  echo "║           LOCK ISSUE DIAGNOSIS REPORT                           ║"
  echo "╚════════════════════════════════════════════════════════════════╝"
  echo ""
  echo "Generated at: $(date '+%Y-%m-%d %H:%M:%S')"
  echo "Database: $DBNAME @ $DBHOST:$DBPORT"
  echo ""

  local issues=0

  # Section 1: Current Blocking
  colorize yellow "═══ CURRENT BLOCKING CHAINS ═══"
  echo ""

  local blocking_count
  blocking_count=$(q_scalar "SELECT count(*) FROM pg_locks WHERE NOT granted;" 2>/dev/null || echo 0)

  echo "Blocked lock requests: $blocking_count"
  echo ""

  if [ "$blocking_count" -gt 0 ]; then
    q "SELECT
      blocked_locks.pid AS blocked_pid,
      blocked_activity.usename AS blocked_user,
      blocking_locks.pid AS blocking_pid,
      blocking_activity.usename AS blocking_user,
      blocked_activity.query AS blocked_query,
      blocking_activity.query AS blocking_query
    FROM pg_catalog.pg_locks blocked_locks
    JOIN pg_catalog.pg_stat_activity blocked_activity ON blocked_activity.pid = blocked_locks.pid
    JOIN pg_catalog.pg_locks blocking_locks ON blocking_locks.locktype = blocked_locks.locktype
      AND blocking_locks.database IS NOT DISTINCT FROM blocked_locks.database
      AND blocking_locks.relation IS NOT DISTINCT FROM blocked_locks.relation
      AND blocking_locks.page IS NOT DISTINCT FROM blocked_locks.page
      AND blocking_locks.tuple IS NOT DISTINCT FROM blocked_locks.tuple
      AND blocking_locks.virtualxid IS NOT DISTINCT FROM blocked_locks.virtualxid
      AND blocking_locks.transactionid IS NOT DISTINCT FROM blocked_locks.transactionid
      AND blocking_locks.classid IS NOT DISTINCT FROM blocked_locks.classid
      AND blocking_locks.objid IS NOT DISTINCT FROM blocked_locks.objid
      AND blocking_locks.objsubid IS NOT DISTINCT FROM blocked_locks.objsubid
      AND blocking_locks.pid != blocked_locks.pid
    JOIN pg_catalog.pg_stat_activity blocking_activity ON blocking_activity.pid = blocking_locks.pid
    WHERE NOT blocked_locks.granted AND blocking_locks.granted;" 2>/dev/null
    echo ""

    if [ "$blocking_count" -gt 5 ]; then
      colorize red "CRITICAL: $blocking_count blocked sessions detected"
      issues=$((issues + 1))
    elif [ "$blocking_count" -gt 0 ]; then
      colorize yellow "WARNING: $blocking_count blocked sessions detected"
      issues=$((issues + 1))
    fi
  else
    colorize green "OK: No blocking sessions currently"
  fi
  echo ""

  # Section 2: Lock Waits
  colorize yellow "═══ LOCK WAIT ANALYSIS ═══"
  echo ""

  q "SELECT wait_event_type, wait_event, count(*) as count
    FROM pg_stat_activity
    WHERE wait_event_type = 'Lock'
    GROUP BY wait_event_type, wait_event
    ORDER BY count DESC;" 2>/dev/null
  echo ""

  # Section 3: Long-running transactions
  colorize yellow "═══ LONG-RUNNING TRANSACTIONS ═══"
  echo ""

  local long_tx_count
  long_tx_count=$(q_scalar "SELECT count(*) FROM pg_stat_activity
    WHERE xact_start < now() - interval '5 minutes'
    AND state != 'idle';" 2>/dev/null || echo 0)

  echo "Active transactions > 5min: $long_tx_count"

  if [[ "$long_tx_count" =~ ^[0-9]+$ ]] && [ "$long_tx_count" -gt 0 ]; then
    colorize yellow "WARNING: $long_tx_count long-running active transaction(s)"
    issues=$((issues + 1))

    q "SELECT pid, usename, now() - xact_start as duration,
         state, LEFT(query, 100) as query
       FROM pg_stat_activity
       WHERE xact_start < now() - interval '5 minutes'
       AND state != 'idle'
       ORDER BY xact_start LIMIT 5;" 2>/dev/null
  fi
  echo ""

  # Section 4: Deadlock Info
  colorize yellow "═══ DEADLOCK INFORMATION ═══"
  echo ""

  local deadlocks
  deadlocks=$(q_scalar "SELECT sum(deadlocks) FROM pg_stat_database;" 2>/dev/null || echo 0)
  echo "Total deadlocks detected: $deadlocks"

  if [[ "$deadlocks" =~ ^[0-9]+$ ]] && [ "$deadlocks" -gt 0 ]; then
    colorize yellow "Note: $deadlocks deadlock(s) have occurred"
    echo "Review PostgreSQL logs for deadlock details"
  fi
  echo ""

  # Summary
  colorize yellow "═══ LOCK ISSUE SUMMARY ═══"
  echo ""
  if [ "$issues" -eq 0 ]; then
    colorize green "Lock Status: HEALTHY - No lock issues detected"
  else
    colorize yellow "Lock Status: $issues issue(s) detected"
    echo ""
    echo "Recommendations:"
    echo "  - Identify and terminate long-running transactions if safe"
    echo "  - Review application transaction patterns"
    echo "  - Consider reducing statement_timeout"
    echo "  - Check for missing indexes causing table scans"
  fi
  echo ""
}

cmd_diagnose()
{
  local scenario="$1"
  shift

  case "$scenario" in
    slow_query|slow|query)    cmd_diagnose_slow_query "$@" ;;
    lock_issue|lock|blocking)  cmd_diagnose_lock_issue "$@" ;;
    connection|conn)           cmd_diagnose_connection "$@" ;;
    replication|repl)          cmd_diagnose_replication "$@" ;;
    performance|perf)          cmd_diagnose_performance "$@" ;;
    health|full)               cmd_diagnose_health "$@" ;;
    capacity|capacity_plan)    cmd_diagnose_capacity "$@" ;;
    *)
      echo "Usage: $EXEC_NAME diagnose <scenario> [options]"
      echo ""
      echo "Scenarios:"
      echo "  slow_query [pid]     - Slow query complete diagnosis"
      echo "  lock_issue           - Lock problem complete diagnosis"
      echo "  connection           - Connection pool problem diagnosis"
      echo "  replication          - Replication problem diagnosis"
      echo "  performance          - Performance degradation diagnosis"
      echo "  health               - Comprehensive health check"
      echo "  capacity             - Capacity planning analysis"
      ;;
  esac
}

