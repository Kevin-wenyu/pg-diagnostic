# ============================================
# SQLCHECK - SQL DIAGNOSIS
# ============================================

cmd_sqlcheck()
{
  local sql_query=""
  local output_format="table"
  local compare_mode=false
  local sql_file=""
  local sql2=""

  # Parse arguments
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --json) output_format="json"; shift ;;
      --compare) compare_mode=true; shift ;;
      --file|-f) sql_file="$2"; shift 2 ;;
      *)
        if [ -z "$sql_query" ]; then
          sql_query="$1"
        elif [ "$compare_mode" = true ] && [ -z "$sql2" ]; then
          sql2="$1"
        fi
        shift
        ;;
    esac
  done

  # If file specified, read from file
  if [ -n "$sql_file" ]; then
    if [ -f "$sql_file" ]; then
      sql_query=$(cat "$sql_file")
    else
      echo "Error: File not found: $sql_file"
      return 1
    fi
  fi

  if [ -z "$sql_query" ]; then
    echo "Usage: $EXEC_NAME sqlcheck \"<sql>\" [options]"
    echo "       $EXEC_NAME sqlcheck --file query.sql"
    echo "       $EXEC_NAME sqlcheck --compare \"<sql1>\" \"<sql2>\""
    echo ""
    echo "Options:"
    echo "  --json              Output results as JSON"
    echo "  --compare <sql2>    Compare two SQL statements"
    echo "  --file <path>       Read SQL from file"
    echo ""
    echo "Examples:"
    echo "  $EXEC_NAME sqlcheck \"SELECT * FROM users WHERE id = 1\""
    echo "  $EXEC_NAME sqlcheck --compare \"SELECT * FROM t\" \"SELECT id FROM t\""
    return 1
  fi

  # Validate SQL starts with SELECT (safety check)
  local sql_upper
  sql_upper=$(echo "$sql_query" | tr '[:lower:]' '[:upper:]' | tr -d '[:space:]')
  if [[ ! "$sql_upper" =~ ^SELECT ]]; then
    echo "Error: Only SELECT statements are allowed for safety"
    return 1
  fi

  if [ "$compare_mode" = true ] && [ -n "$sql2" ]; then
    sqlcheck_compare "$sql_query" "$sql2"
  else
    sqlcheck_analyze "$sql_query" "$output_format"
  fi
}

sqlcheck_analyze()
{
  local sql="$1"
  local format="${2:-table}"

  echo ""
  echo "╔════════════════════════════════════════════════════════════════╗"
  echo "║          🔍 SQL DIAGNOSIS REPORT                                ║"
  echo "╚════════════════════════════════════════════════════════════════╝"
  echo ""
  echo "SQL: ${sql:0:100}"
  if [ ${#sql} -gt 100 ]; then
    echo "    ${sql:100:100}"
  fi
  echo ""

  # Section 1: Query Plan Analysis
  colorize yellow "═══ QUERY PLAN ANALYSIS ═══"
  echo ""
  q "EXPLAIN (ANALYZE, BUFFERS, FORMAT TEXT) $sql;"
  echo ""

  # Section 2: Estimated Cost Analysis
  colorize yellow "═══ COST ESTIMATION ═══"
  echo ""
  local plan_json
  plan_json=$(q "EXPLAIN (FORMAT JSON) $sql;" 2>/dev/null)

  if [ -n "$plan_json" ]; then
    echo "   Plan Summary:"
    echo "$plan_json" | grep -E '(Plan|Total Cost|Startup Cost|Actual Rows|Actual Time)' | head -10 | sed 's/^/   /'
  fi
  echo ""

  # Section 3: Table Statistics
  colorize yellow "═══ INVOLVED TABLES ═══"
  echo ""

  # Extract table names from SQL (simple extraction)
  local tables
  tables=$(echo "$sql" | grep -oEi 'FROM\s+[a-zA-Z_][a-zA-Z0-9_]*' | sed 's/FROM//i' | tr -d ' ' | sort -u)
  tables="$tables $(echo "$sql" | grep -oEi 'JOIN\s+[a-zA-Z_][a-zA-Z0-9_]*' | sed 's/JOIN//i' | tr -d ' ' | sort -u)"

  for table in $tables; do
    if [ -n "$table" ]; then
      echo "   Table: $table"
      q "SELECT
        pg_size_pretty(pg_total_relation_size('$table'::regclass)) as total_size,
        n_live_tup as row_count,
        n_dead_tup as dead_tuples,
        last_vacuum,
        last_analyze
      FROM pg_stat_user_tables
      WHERE relname = '$table'
      LIMIT 1;" 2>/dev/null || echo "      (statistics not available)"
      echo ""
    fi
  done

  # Section 4: Index Recommendations
  colorize yellow "═══ INDEX RECOMMENDATIONS ═══"
  echo ""

  for table in $tables; do
    if [ -n "$table" ]; then
      # Check existing indexes
      local idx_count
      idx_count=$(q_scalar "SELECT count(*) FROM pg_indexes WHERE tablename = '$table';" 2>/dev/null || echo 0)
      echo "   Table '$table': $idx_count existing index(es)"

      # Show existing indexes
      q "SELECT
        indexname,
        pg_size_pretty(pg_relation_size(indexrelname::regclass)) as idx_size
      FROM pg_indexes
      WHERE tablename = '$table';" 2>/dev/null
      echo ""
    fi
  done

  # Section 5: Optimization Suggestions
  colorize yellow "═══ OPTIMIZATION SUGGESTIONS ═══"
  echo ""

  # Check for common patterns
  local sql_upper
  sql_upper=$(echo "$sql" | tr '[:lower:]' '[:upper:]')

  if echo "$sql_upper" | grep -q 'SELECT \*'; then
    echo "   ⚠️  Consider selecting specific columns instead of SELECT *"
    echo "       This reduces I/O and memory usage."
    echo ""
  fi

  if echo "$sql_upper" | grep -qE 'ORDER BY.*DESC|ORDER BY.*ASC'; then
    echo "   ℹ️  Ensure proper indexes exist for ORDER BY columns"
    echo ""
  fi

  if echo "$sql_upper" | grep -q 'LIKE'; then
    echo "   ⚠️  LIKE patterns starting with % cannot use indexes"
    echo "      Consider full-text search (to_tsvector) for text matching."
    echo ""
  fi

  if echo "$sql_upper" | grep -qE 'OFFSET\s+[0-9]+'; then
    echo "   ⚠️  Large OFFSET values are inefficient"
    echo "      Consider keyset pagination (WHERE id > last_id LIMIT n)."
    echo ""
  fi

  # Check for LIMIT without ORDER BY
  if echo "$sql_upper" | grep -q 'LIMIT' && ! echo "$sql_upper" | grep -q 'ORDER BY'; then
    echo "   ⚠️  LIMIT without ORDER BY returns arbitrary rows"
    echo "      Add ORDER BY for deterministic results."
    echo ""
  fi

  echo ""
  colorize green "Analysis complete."
  echo ""
}

sqlcheck_compare()
{
  local sql1="$1"
  local sql2="$2"

  echo ""
  echo "╔════════════════════════════════════════════════════════════════╗"
  echo "║          🔄 SQL COMPARISON ANALYSIS                             ║"
  echo "╚════════════════════════════════════════════════════════════════╝"
  echo ""

  echo "SQL 1: ${sql1:0:80}..."
  echo ""
  echo "SQL 2: ${sql2:0:80}..."
  echo ""

  colorize yellow "═══ PLAN COMPARISON ═══"
  echo ""

  echo "Plan 1:"
  q "EXPLAIN (ANALYZE, FORMAT TEXT) $sql1;"
  echo ""

  echo "Plan 2:"
  q "EXPLAIN (ANALYZE, FORMAT TEXT) $sql2;"
  echo ""

  colorize yellow "═══ COST COMPARISON ═══"
  echo ""

  local cost1 cost2
  cost1=$(q_scalar "EXPLAIN (FORMAT JSON) $sql1;" 2>/dev/null | grep -oE '"Total Cost": [0-9.]+' | head -1 | grep -oE '[0-9.]+')
  cost2=$(q_scalar "EXPLAIN (FORMAT JSON) $sql2;" 2>/dev/null | grep -oE '"Total Cost": [0-9.]+' | head -1 | grep -oE '[0-9.]+')

  if [ -n "$cost1" ] && [ -n "$cost2" ]; then
    echo "   SQL 1 Cost: $cost1"
    echo "   SQL 2 Cost: $cost2"

    if (( $(echo "$cost1 < $cost2" | bc -l) )); then
      echo ""
      colorize green "   ✅ SQL 1 has lower estimated cost"
    elif (( $(echo "$cost1 > $cost2" | bc -l) )); then
      echo ""
      colorize green "   ✅ SQL 2 has lower estimated cost"
    else
      echo "   ℹ️  Similar estimated costs"
    fi
  fi

  echo ""
}

