cmd_slot_lag()
{
  # Parse parameters
  local limit=20

  while [[ $# -gt 0 ]]; do
    case "$1" in
      -n|--limit) limit="$2"; shift 2 ;;
      *) shift ;;
    esac
  done

  # Validate limit is numeric
  if ! [[ "$limit" =~ ^[0-9]+$ ]]; then
    msg_error "--limit must be a positive integer"
    return 1
  fi

  local output
  output=$(q "$SQL_REPLICATION_SLOT_LAG" 2>/dev/null)

  if [ -z "$output" ]; then
    msg_info "No replication slots found"
    return 0
  fi

  # Display header
  colorize blue "=== REPLICATION SLOT LAG ==="
  echo ""

  # Show the slot data with limit
  echo "$output" | head -n $((limit + 2))  # +2 for header lines

  echo ""

  # Check for high-lag slots (more than 1GB)
  local high_lag_slots
  high_lag_slots=$(q "SELECT slot_name, pg_size_pretty(pg_wal_lsn_diff(pg_current_wal_lsn(), restart_lsn)) AS lag
    FROM pg_replication_slots
    WHERE pg_wal_lsn_diff(pg_current_wal_lsn(), restart_lsn) > 1073741824
    ORDER BY lag DESC" 2>/dev/null)

  if [ -n "$high_lag_slots" ]; then
    colorize yellow "⚠️  HIGH LAG SLOTS (>1GB):"
    echo "$high_lag_slots"
    echo ""
  fi

  # Check for inactive slots
  local inactive_slots
  inactive_slots=$(q "SELECT slot_name, pg_size_pretty(pg_wal_lsn_diff(pg_current_wal_lsn(), restart_lsn)) AS retained
    FROM pg_replication_slots
    WHERE NOT active
    ORDER BY pg_wal_lsn_diff(pg_current_wal_lsn(), restart_lsn) DESC" 2>/dev/null)

  if [ -n "$inactive_slots" ]; then
    colorize red "🚨 INACTIVE SLOTS (WAL bloat risk):"
    echo "$inactive_slots"
    echo ""
    echo "Recommendation: Remove inactive slots if no longer needed:"
    echo "  SELECT pg_drop_replication_slot('slot_name');"
  fi
}

