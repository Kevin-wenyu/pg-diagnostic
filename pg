cmd_set_config()
{
  local name=$1 value=$2
  [ -z "$name" ] || [ -z "$value" ] && { echo "Usage: $EXEC_NAME set_config <name> <value>"; return 1; }

  # Sanitize both name and value to prevent SQL injection
  local sanitized_name
  sanitized_name=$(q_sanitize "$name")
  local sanitized_value
  sanitized_value=$(q_sanitize "$value")

  # Validate parameter name format (should be a valid PostgreSQL parameter name)
  if [[ ! "$sanitized_name" =~ ^[a-zA-Z][a-zA-Z0-9_.]*$ ]]; then
    echo "Error: Invalid parameter name format" >&2
    return 1
  fi

  # Block potentially dangerous parameters that could compromise security
  local dangerous_params=(
    "log_statement"
    "log_min_messages"
    "log_min_error_statement"
    "shared_preload_libraries"
    "session_preload_libraries"
    "local_preload_libraries"
    "dynamic_library_path"
    "listen_addresses"
    "port"
    "password_encryption"
    "ssl"
    "ssl_cert_file"
    "ssl_key_file"
    "ssl_ca_file"
    "ssl_ciphers"
    "log_directory"
    "log_filename"
    "logging_collector"
    "log_destination"
  )

  local param_lower
  param_lower=$(echo "$sanitized_name" | tr '[:upper:]' '[:lower:]')
  for dangerous_param in "${dangerous_params[@]}"; do
    if [ "$param_lower" = "$dangerous_param" ]; then
      echo "Error: Setting parameter '$sanitized_name' is not allowed for security reasons" >&2
      return 1
    fi
  done

  q "SET $sanitized_name = '$sanitized_value'; SELECT current_setting('$sanitized_name') AS new_value;"
}

cmd_watch()
{
  local secs=$1; shift
  [ -z "$secs" ] && { echo "Usage: $EXEC_NAME watch <seconds> <command>"; return 1; }
  [[ ! "$secs" =~ ^[0-9]+$ ]] && { echo "Error: seconds must be numeric"; return 1; }
  [ $# -eq 0 ] && { echo "Error: no command specified"; return 1; }
  
  while true; do
    clear
    echo "$(date '+%Y-%m-%d %H:%M:%S') - Refresh every ${secs}s"
    echo "========================================"
    dispatch_command "$@"
    sleep "$secs"
  done
}

