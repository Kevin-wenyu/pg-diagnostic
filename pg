cmd_parallel_efficiency()
{
  if [ -z "$(extension_installed pg_stat_statements)" ]; then
    echo "Error: pg_stat_statements extension not installed"
    return 1
  fi

  local limit=${1:-$TOP_N}
  init_pg_stat_statements_columns || return 1

  q "SELECT LEFT(query, 100) AS query_snippet,
       calls,
       round(CAST(${PGS_TOTAL_COL} AS numeric)) AS total_exec_time_ms,
       shared_blks_dirtied, shared_blks_written,
       temp_blks_written
     FROM pg_stat_statements
     WHERE shared_blks_dirtied > 0 OR temp_blks_written > 0
     ORDER BY shared_blks_dirtied DESC
     LIMIT $limit;"
}

