cmd_io_stats()
{
  if [ "${PG_MAJOR_VERSION:-0}" -ge 17 ]; then
    # PostgreSQL 17+ has pg_stat_io with different columns
    q "SELECT backend_type, object, context,
         read_bytes, write_bytes, extend_bytes,
         COALESCE(read_bytes, 0) + COALESCE(write_bytes, 0) AS total_bytes,
         hits, evictions
       FROM pg_stat_io
       WHERE read_bytes > 0 OR write_bytes > 0
       ORDER BY COALESCE(read_bytes, 0) + COALESCE(write_bytes, 0) DESC
       LIMIT $TOP_N;"
  else
    q "SELECT schemaname, relname AS \"table\",
         heap_blks_read, heap_blks_hit,
         CASE
           WHEN heap_blks_hit + heap_blks_read = 0 THEN NULL
           ELSE ROUND(100.0 * heap_blks_hit / (heap_blks_hit + heap_blks_read), 2)
         END AS hit_ratio
       FROM pg_statio_user_tables
       WHERE heap_blks_read > 0
       ORDER BY heap_blks_read DESC
       LIMIT $TOP_N;"
  fi
}

cmd_wait_events()
{
  colorize yellow "WAIT EVENTS SUMMARY:"
  echo ""

  local query
  if [ "$PG_MAJOR_VERSION" -ge 10 ]; then
    query="SELECT wait_event_type, wait_event, count(*) as cnt,
      round(100.0 * count(*) / sum(count(*)) over(), 2) as pct
    FROM pg_stat_activity
    WHERE wait_event IS NOT NULL
      AND wait_event_type IS NOT NULL
      AND state != 'idle'
    GROUP BY wait_event_type, wait_event
    ORDER BY count(*) DESC
    LIMIT 15;"
  else
    query="SELECT wait_event, count(*) as cnt
    FROM pg_stat_activity
    WHERE wait_event IS NOT NULL
    GROUP BY wait_event
    ORDER BY count(*) DESC
    LIMIT 15;"
  fi

  q "$query"
  echo ""

  # TOP 等待事件解读 - 从上面的结果中第一行就是最频繁的
  # 重新查询确保一致性（数据变化时可能略有差异，但这是可接受的）
  local has_events
  has_events=$(q_scalar "SELECT count(*) FROM pg_stat_activity
    WHERE wait_event IS NOT NULL AND state != 'idle';")

  if [ "$has_events" -gt 0 ]; then
    colorize yellow "TOP WAIT EVENT INTERPRETATION:"
    local top_combined
    top_combined=$(q_scalar "SELECT wait_event_type || ':' || wait_event FROM pg_stat_activity
      WHERE wait_event IS NOT NULL AND state != 'idle'
      GROUP BY wait_event_type, wait_event ORDER BY count(*) DESC LIMIT 1;")

    local top_type="${top_combined%%:*}"
    local top_event="${top_combined#*:}"

    echo "  Most frequent: $top_combined"
    interpret_wait_event "$top_type" "$top_event"
  fi
}

