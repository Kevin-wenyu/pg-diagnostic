       round(${PGS_MAX_COL}) AS max_time_ms,
       shared_blks_read + local_blks_read + temp_blks_read AS total_reads,
       shared_blks_hit + local_blks_hit AS total_hits,
       round((shared_blks_hit + local_blks_hit)::numeric * 100 /
             NULLIF(shared_blks_hit + local_blks_hit + shared_blks_read + local_blks_read, 0), 2) AS io_efficiency_pct,
