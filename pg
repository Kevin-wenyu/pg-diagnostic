readonly SQL_LOCKS_ACTIVE="SELECT l.locktype, l.mode, l.granted, a.pid, a.usename,
    COALESCE(c.relname, '') AS relation,
    LEFT(a.query, 60) AS query
FROM pg_locks l
JOIN pg_stat_activity a ON l.pid = a.pid
LEFT JOIN pg_class c ON l.relation = c.oid
WHERE l.relation IS NOT NULL OR l.locktype IN ('transactionid', 'virtualxid')
