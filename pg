# ============================================

workflow_lock_issue()
{
  echo ""
  echo "╔════════════════════════════════════════════════════════════════╗"
  echo "║          🔒 LOCK ISSUE DIAGNOSIS WORKFLOW                       ║"
  echo "╚════════════════════════════════════════════════════════════════╝"
  echo ""

  # Step 1: Current lock conflicts
  workflow_step 1 3 "Current Lock Conflicts"

  local blocked_count
  blocked_count=$(q_scalar "SELECT count(*) FROM pg_locks WHERE NOT granted;" 2>/dev/null || echo 0)

  if [[ "$blocked_count" =~ ^[0-9]+$ ]] && [ "$blocked_count" -gt 0 ]; then
    workflow_result critical "$blocked_count sessions are blocked"
    echo ""
    echo "   Blocking details:"
    q "SELECT
      blocked_locks.pid AS blocked_pid,
      blocked_activity.usename AS blocked_user,
      blocking_locks.pid AS blocking_pid,
      blocking_activity.usename AS blocking_user,
      blocked_activity.query AS blocked_query,
      blocking_activity.query AS blocking_query,
      blocked_locks.mode AS blocked_mode,
      blocking_locks.mode AS blocking_mode
    FROM pg_catalog.pg_locks blocked_locks
    JOIN pg_catalog.pg_stat_activity blocked_activity ON blocked_activity.pid = blocked_locks.pid
    JOIN pg_catalog.pg_locks blocking_locks ON blocking_locks.locktype = blocked_locks.locktype
        AND blocking_locks.relation = blocked_locks.relation
        AND blocking_locks.pid != blocked_locks.pid
    JOIN pg_catalog.pg_stat_activity blocking_activity ON blocking_activity.pid = blocking_locks.pid
    WHERE NOT blocked_locks.granted
      AND blocking_locks.granted;"
  else
    workflow_result ok "No blocking locks currently"
  fi

  # Step 2: Lock wait analysis
  workflow_step 2 3 "Lock Wait Analysis"

  echo "   Sessions waiting on locks:"
  q "SELECT
    pid,
    usename,
    application_name,
    state,
    wait_event_type,
    wait_event,
    now() - state_change as wait_duration,
    LEFT(query, 60) as query_preview
  FROM pg_stat_activity
  WHERE wait_event_type = 'Lock'
  ORDER BY state_change;"

  # Step 3: Long-running transactions
  workflow_step 3 3 "Long-Running Transactions"

  echo "   Transactions running > 1 minute:"
  q "SELECT
    pid,
    usename,
    application_name,
    xact_start,
    now() - xact_start as duration,
    state,
    LEFT(query, 60) as query_preview
  FROM pg_stat_activity
  WHERE xact_start IS NOT NULL
    AND now() - xact_start > interval '1 minute'
  ORDER BY xact_start;"

  echo ""
  colorize yellow "💡 Recommendations:"
  echo "   1. Consider terminating long-running idle transactions"
  echo "   2. Review application transaction handling"
  echo "   3. Set idle_in_transaction_session_timeout appropriately"
  echo "   4. Investigate frequent lock conflicts in application design"
  echo ""
}

