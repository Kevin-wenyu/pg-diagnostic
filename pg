cmd_privilege_audit()
{
  q "WITH dangerous_perms AS (
       SELECT 'SUPERUSER' AS perm_type, rolname AS role_name, rolcreatedb, rolcreaterole, rolsuper
       FROM pg_roles
       WHERE rolsuper = true
       UNION ALL
       SELECT 'CREATEDB' AS perm_type, rolname AS role_name, rolcreatedb, rolcreaterole, rolsuper
       FROM pg_roles
       WHERE rolcreatedb = true AND rolsuper = false
       UNION ALL
       SELECT 'CREATEROLE' AS perm_type, rolname AS role_name, rolcreatedb, rolcreaterole, rolsuper
       FROM pg_roles
       WHERE rolcreaterole = true AND rolsuper = false AND rolcreatedb = false
     )
     SELECT perm_type, role_name, rolsuper, rolcreatedb, rolcreaterole
     FROM dangerous_perms
     ORDER BY perm_type, role_name;"
}

cmd_security_checks()
{
  q "SELECT name, setting, unit, context, source,
       CASE
         WHEN name = 'log_statement' AND setting = 'none' THEN 'WARNING'
         WHEN name = 'log_min_error_statement' AND setting = 'panic' THEN 'WARNING'
         WHEN name = 'log_connections' AND setting = 'off' THEN 'INFO'
         WHEN name = 'log_disconnections' AND setting = 'off' THEN 'INFO'
         WHEN name = 'log_lock_waits' AND setting = 'off' THEN 'WARNING'
         WHEN name = 'password_encryption' AND setting = 'off' THEN 'CRITICAL'
         WHEN name = 'log_hostname' AND setting = 'off' THEN 'INFO'
         ELSE 'OK'
       END AS severity
     FROM pg_settings
     WHERE name IN ('log_statement', 'log_min_error_statement', 'log_connections',
                    'log_disconnections', 'log_lock_waits', 'password_encryption', 'log_hostname')
     ORDER BY severity DESC, name;"
}

cmd_user_access_pattern()
{
  local limit=${1:-$TOP_N}
  q "SELECT usename, application_name, count(*) AS session_count,
       min(backend_start) AS first_seen,
       max(backend_start) AS last_seen,
       count(DISTINCT client_addr) AS ip_count
     FROM pg_stat_activity
     WHERE backend_start > now() - interval '7 days'
     GROUP BY usename, application_name
     ORDER BY session_count DESC
     LIMIT $limit;"
}

