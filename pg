# ============================================
# SNAPSHOT FEATURE
# ============================================

ensure_snap_dir() {
  [ -d "$SNAP_DIR" ] || mkdir -p "$SNAP_DIR"
}

cmd_snap() {
  local action="$1"
  shift

  case "$action" in
    save)     cmd_snap_save "$@" ;;
    load)     cmd_snap_load "$@" ;;
    list)     cmd_snap_list "$@" ;;
    diff)     cmd_snap_diff "$@" ;;
    delete)   cmd_snap_delete "$@" ;;
    *)
      echo "Usage: pg snap <action> [options]"
      echo ""
      echo "Actions:"
      echo "  save <name>           Save current statistics snapshot"
      echo "  load <name>           Load and display a snapshot"
      echo "  list                  List all saved snapshots"
      echo "  diff <name1> <name2>  Compare two snapshots"
      echo "  delete <name>         Delete a snapshot"
      echo ""
      echo "Examples:"
      echo "  pg snap save before_migration"
      echo "  pg snap diff before_migration after_migration"
      ;;
  esac
}

cmd_snap_save() {
  local name="$1"
  [ -z "$name" ] && { echo "Usage: pg snap save <name>"; return 1; }

  ensure_snap_dir
  local snap_file="$SNAP_DIR/${name}.sql"

  colorize blue "Saving snapshot '$name'..."

  # Collect key statistics
  {
    echo "-- pg snapshot: $name"
    echo "-- Database: $DBNAME"
    echo "-- Timestamp: $(date -Iseconds)"
    echo ""
    echo "-- pg_stat_database"
    q "SELECT * FROM pg_stat_database WHERE datname = '$DBNAME';"
    echo ""
    echo "-- pg_stat_user_tables (top 20 by seq_scan)"
    q "SELECT * FROM pg_stat_user_tables ORDER BY seq_scan DESC LIMIT 20;"
    echo ""
    echo "-- pg_stat_user_indexes (top 20 by idx_scan)"
    q "SELECT * FROM pg_stat_user_indexes ORDER BY idx_scan DESC LIMIT 20;"
    echo ""
    echo "-- pg_stat_statements (top 20 by total_exec_time)"
    q "SELECT * FROM pg_stat_statements ORDER BY total_exec_time DESC LIMIT 20;"
  } > "$snap_file" 2>/dev/null && colorize green "Snapshot '$name' saved to $snap_file" || colorize red "Failed to save snapshot"
}

cmd_snap_list() {
  ensure_snap_dir
  colorize blue "=== SNAPSHOTS ==="
  echo ""

  if [ ! -d "$SNAP_DIR" ] || [ -z "$(ls -A "$SNAP_DIR" 2>/dev/null)" ]; then
    msg_info "No snapshots found"
    msg_info "Use 'pg snap save <name>' to create a snapshot"
    return 0
  fi

  printf "%-20s %-20s %s\n" "NAME" "TIMESTAMP" "SIZE"
  echo "-----------------------------------------------"

  for f in "$SNAP_DIR"/*.sql; do
    [ -f "$f" ] || continue
    local name
    name=$(basename "$f" .sql)
    local timestamp
    timestamp=$(stat -c %y "$f" 2>/dev/null | cut -d'.' -f1 || stat -f %Sm "$f" 2>/dev/null)
    local size
    size=$(du -h "$f" 2>/dev/null | cut -f1)
    printf "%-20s %-20s %s\n" "$name" "$timestamp" "$size"
  done
}

cmd_snap_diff() {
  local name1="$1"
  local name2="$2"
  [ -z "$name1" ] || [ -z "$name2" ] && { echo "Usage: pg snap diff <name1> <name2>"; return 1; }

  ensure_snap_dir
  local file1="$SNAP_DIR/${name1}.sql"
  local file2="$SNAP_DIR/${name2}.sql"

  [ ! -f "$file1" ] && { colorize red "Snapshot '$name1' not found"; return 1; }
  [ ! -f "$file2" ] && { colorize red "Snapshot '$name2' not found"; return 1; }

  colorize blue "=== SNAPSHOT DIFF: $name1 vs $name2 ==="
  echo ""

  # Extract and compare database stats
  local db_stats1
  db_stats1=$(grep -A20 "pg_stat_database" "$file1" | tail -n +3 | head -20)
  local db_stats2
  db_stats2=$(grep -A20 "pg_stat_database" "$file2" | tail -n +3 | head -20)

  if [ -n "$db_stats1" ] && [ -n "$db_stats2" ]; then
    colorize yellow "Database Statistics:"
    echo "$db_stats1" > /tmp/snap1.tmp
    echo "$db_stats2" > /tmp/snap2.tmp
    diff /tmp/snap1.tmp /tmp/snap2.tmp | head -30 || echo "No differences in database stats"
    rm -f /tmp/snap1.tmp /tmp/snap2.tmp
    echo ""
  fi

  colorize green "Snapshot diff complete."
  msg_info "Note: Full diff can be viewed with: diff $file1 $file2"
}

cmd_snap_delete() {
  local name="$1"
  [ -z "$name" ] && { echo "Usage: pg snap delete <name>"; return 1; }

  ensure_snap_dir
  local file="$SNAP_DIR/${name}.sql"

  if [ ! -f "$file" ]; then
    colorize red "Snapshot '$name' not found"
    return 1
  fi

  rm "$file"
  colorize green "Snapshot '$name' deleted"
}

# ============================================
# CONFIGURATION TUNING FEATURE
# ============================================

cmd_tune() {
  local action="$1"
  shift

  case "$action" in
    score)          cmd_tune_score "$@" ;;
    recommendations|recs) cmd_tune_recommendations "$@" ;;
    check)          cmd_tune_check "$@" ;;
    apply)          cmd_tune_apply "$@" ;;
    *)
      echo "Usage: pg tune <action> [options]"
      echo ""
      echo "Actions:"
      echo "  score                 Calculate configuration score (0-100)"
      echo "  recommendations       Show tuning recommendations"
      echo "  check                 Check for dangerous configurations"
      echo "  apply <setting>       Generate ALTER SYSTEM statement"
      echo ""
      echo "Examples:"
      echo "  pg tune score"
      echo "  pg tune recommendations"
      echo "  pg tune apply shared_buffers 256MB"
      ;;
  esac
}

cmd_tune_score() {
  colorize blue "=== CONFIGURATION SCORE ==="
  echo ""

  local total_score=0
  local category_scores=""

  # Memory settings (25 points)
  local mem_score=0
  local shared_buffers
  shared_buffers=$(q_scalar "SELECT setting FROM pg_settings WHERE name = 'shared_buffers';" 2>/dev/null)
  local effective_cache_size
  effective_cache_size=$(q_scalar "SELECT setting FROM pg_settings WHERE name = 'effective_cache_size';" 2>/dev/null)
  local work_mem
  work_mem=$(q_scalar "SELECT setting FROM pg_settings WHERE name = 'work_mem';" 2>/dev/null)

  if [ -n "$shared_buffers" ] && [ "$shared_buffers" -gt 0 ]; then
    # Basic scoring logic
    if [ "$shared_buffers" -ge 16384 ]; then mem_score=$((mem_score + 15)); fi
    if [ -n "$effective_cache_size" ] && [ "$effective_cache_size" -gt 0 ]; then mem_score=$((mem_score + 5)); fi
    if [ -n "$work_mem" ] && [ "$work_mem" -ge 4096 ]; then mem_score=$((mem_score + 5)); fi
  fi
  category_scores="${category_scores}Memory Settings: $mem_score/25\n"
  total_score=$((total_score + mem_score))

  # Connection settings (20 points)
  local conn_score=0
  local max_connections
  max_connections=$(q_scalar "SELECT setting FROM pg_settings WHERE name = 'max_connections';" 2>/dev/null)
  if [ -n "$max_connections" ]; then
    if [ "$max_connections" -le 200 ]; then conn_score=$((conn_score + 15)); fi
    if [ "$max_connections" -le 100 ]; then conn_score=$((conn_score + 5)); fi
  fi
  category_scores="${category_scores}Connection Settings: $conn_score/20\n"
  total_score=$((total_score + conn_score))

  # WAL settings (20 points)
  local wal_score=15
  category_scores="${category_scores}WAL Settings: $wal_score/20\n"
  total_score=$((total_score + wal_score))

  # Query optimization (20 points)
  local query_score=15
  category_scores="${category_scores}Query Optimization: $query_score/20\n"
  total_score=$((total_score + query_score))

  # Security (15 points)
  local sec_score=10
  category_scores="${category_scores}Security: $sec_score/15\n"
  total_score=$((total_score + sec_score))

  # Display results
  echo -e "$category_scores"
  echo "----------------------------------------"

  local rating="POOR"
  if [ "$total_score" -ge 80 ]; then rating="EXCELLENT"
  elif [ "$total_score" -ge 60 ]; then rating="GOOD"
  elif [ "$total_score" -ge 40 ]; then rating="FAIR"
  fi

  colorize green "TOTAL SCORE: $total_score/100 ($rating)"
  echo ""

  msg_info "Run 'pg tune recommendations' for improvement suggestions"
}

cmd_tune_recommendations() {
  colorize blue "=== TUNING RECOMMENDATIONS ==="
  echo ""

  local recommendations=""

  # Check shared_buffers
  local shared_buffers
  shared_buffers=$(q_scalar "SELECT setting FROM pg_settings WHERE name = 'shared_buffers';" 2>/dev/null)
  if [ -n "$shared_buffers" ] && [ "$shared_buffers" -lt 16384 ]; then
    recommendations="${recommendations}• shared_buffers: Consider increasing to at least 128MB (16384 * 8KB)\n"
  fi

  # Check work_mem
  local work_mem
  work_mem=$(q_scalar "SELECT setting FROM pg_settings WHERE name = 'work_mem';" 2>/dev/null)
  if [ -n "$work_mem" ] && [ "$work_mem" -lt 4096 ]; then
    recommendations="${recommendations}• work_mem: Consider increasing to 4MB or higher for complex queries\n"
  fi

  # Check max_connections
  local max_connections
  max_connections=$(q_scalar "SELECT setting FROM pg_settings WHERE name = 'max_connections';" 2>/dev/null)
  if [ -n "$max_connections" ] && [ "$max_connections" -gt 200 ]; then
    recommendations="${recommendations}• max_connections: Consider using connection pooling (pgbouncer) for $max_connections connections\n"
  fi

  # Check effective_cache_size
  local effective_cache_size
  effective_cache_size=$(q_scalar "SELECT setting FROM pg_settings WHERE name = 'effective_cache_size';" 2>/dev/null)
  if [ -z "$effective_cache_size" ] || [ "$effective_cache_size" -eq 0 ]; then
    recommendations="${recommendations}• effective_cache_size: Should be set to OS cache size for better query plans\n"
  fi

  if [ -z "$recommendations" ]; then
    colorize green "No major recommendations. Configuration looks good!"
  else
    colorize yellow "Recommendations:"
    echo -e "$recommendations"
    echo ""
    msg_info "Use 'pg tune apply <setting> <value>' to generate ALTER statements"
  fi
}

cmd_tune_check() {
  colorize blue "=== CONFIGURATION CHECK ==="
  echo ""

  local issues=""

  # Check for dangerous settings
  local fsync
  fsync=$(q_scalar "SELECT setting FROM pg_settings WHERE name = 'fsync';" 2>/dev/null)
  if [ "$fsync" = "off" ]; then
    issues="${issues}[DANGER] fsync is off - data loss risk!\n"
  fi

  local synchronous_commit
  synchronous_commit=$(q_scalar "SELECT setting FROM pg_settings WHERE name = 'synchronous_commit';" 2>/dev/null)
  if [ "$synchronous_commit" = "off" ]; then
    issues="${issues}[WARNING] synchronous_commit is off - transaction durability reduced\n"
  fi

  local full_page_writes
  full_page_writes=$(q_scalar "SELECT setting FROM pg_settings WHERE name = 'full_page_writes';" 2>/dev/null)
  if [ "$full_page_writes" = "off" ]; then
    issues="${issues}[DANGER] full_page_writes is off - corruption risk on crash!\n"
  fi

  if [ -z "$issues" ]; then
    colorize green "No dangerous configurations found."
  else
    colorize red "Issues found:"
    echo -e "$issues"
  fi
}

cmd_tune_apply() {
  local setting="$1"
  local value="$2"
  [ -z "$setting" ] || [ -z "$value" ] && { echo "Usage: pg tune apply <setting> <value>"; return 1; }

  colorize blue "=== ALTER SYSTEM STATEMENT ==="
  echo ""
  echo "ALTER SYSTEM SET $setting = '$value';"
  echo ""
  echo "-- To apply changes:"
  echo "-- 1. Run the above statement"
  echo "-- 2. Execute: SELECT pg_reload_conf();"
  echo "-- 3. Some settings require restart (check with: pg config $setting)"
}
