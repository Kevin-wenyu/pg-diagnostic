# SLA Tracker
cmd_sla_tracker()
{
  local timeframe="${1:-1h}"

  colorize blue "=== SLA TRACKING REPORT ($timeframe) ==="
  echo ""

  q "WITH sla_metrics AS (
       -- Availability: based on uptime and active connections
       SELECT
         'Availability' as metric_name,
         100.0 as value,
         '99.9%' as target,
         'OK' as status

       UNION ALL

       -- Response Time: average query execution time from pg_stat_statements
       SELECT
         'Response Time' as metric_name,
         COALESCE(
           (SELECT round(avg(mean_exec_time)::numeric, 2)
            FROM pg_stat_statements
            WHERE calls > 0
            LIMIT 100),
           0
         ) as value,
         '500 ms' as target,
         CASE
           WHEN COALESCE(
             (SELECT avg(mean_exec_time)::numeric
              FROM pg_stat_statements
              WHERE calls > 0
              LIMIT 100),
             0
           ) < 500 THEN 'OK'
           ELSE 'VIOLATED'
         END as status

       UNION ALL

       -- Throughput: transactions per second from pg_stat_database
       SELECT
         'Throughput (TPS)' as metric_name,
         COALESCE(
           (SELECT round((xact_commit + xact_rollback)::numeric /
                  EXTRACT(epoch FROM (now() - stats_reset)), 2)
            FROM pg_stat_database
            WHERE datname = current_database()),
           0
         ) as value,
         '1000' as target,
         CASE
           WHEN COALESCE(
             (SELECT (xact_commit + xact_rollback)::numeric /
                    EXTRACT(epoch FROM (now() - stats_reset))
              FROM pg_stat_database
              WHERE datname = current_database()),
             0
           ) >= 1000 THEN 'OK'
           ELSE 'VIOLATED'
         END as status
     )
     SELECT metric_name, value, target, status
     FROM sla_metrics;"
}

# Intelligent Alert Engine
cmd_alert_engine()
{
  colorize blue "=== INTELLIGENT ALERT ENGINE ==="
  echo ""

  # Check various enterprise-level alerts
  local issues=0

  # Check connection count - use direct query instead of parsing cmd_conn_limit
  local current_conns max_conns
  current_conns=$(q_scalar "SELECT count(*) FROM pg_stat_activity;")
  max_conns=$(q_scalar "SELECT setting::int FROM pg_settings WHERE name = 'max_connections';")

  # Verify that we have valid numeric values before arithmetic operations
  if [[ "$current_conns" =~ ^[0-9]+$ ]] && [[ "$max_conns" =~ ^[0-9]+$ ]] && [ "$max_conns" -gt 0 ]; then
    local usage_percent
    usage_percent=$((current_conns * 100 / max_conns))

    if [ "$usage_percent" -gt 90 ]; then
      colorize red "CRITICAL: Connection usage at ${usage_percent}% ($current_conns / $max_conns)"
      issues=$((issues+1))
    elif [ "$usage_percent" -gt 80 ]; then
      colorize yellow "WARNING: Connection usage at ${usage_percent}% ($current_conns / $max_conns)"
      issues=$((issues+1))
    else
      echo "OK: Connection usage at ${usage_percent}% ($current_conns / $max_conns)"
    fi
  else
    colorize yellow "WARNING: Unable to determine connection usage"
    issues=$((issues+1))
  fi

  # Check blocking sessions - use direct query
  local blocking_count
  blocking_count=$(q_scalar "SELECT count(*) FROM pg_stat_activity WHERE array_length(pg_blocking_pids(pid), 1) > 0;")
  if [[ "$blocking_count" =~ ^[0-9]+$ ]]; then
    if [ "$blocking_count" -gt 5 ]; then
      colorize red "CRITICAL: $blocking_count blocking sessions detected"
      issues=$((issues+1))
    elif [ "$blocking_count" -gt 0 ]; then
      colorize yellow "WARNING: $blocking_count blocking sessions detected"
      issues=$((issues+1))
    else
      echo "OK: No blocking sessions"
    fi
  else
    colorize yellow "WARNING: Unable to determine blocking session count"
    issues=$((issues+1))
  fi

  # Check slow queries if pg_stat_statements is available
  if [ -n "$(extension_installed pg_stat_statements)" ]; then
    local slow_query_count
    slow_query_count=$(run_stat_statements "SELECT count(*) FROM pg_stat_statements WHERE mean_time > 1000;" 2>/dev/null | head -1)
    if [ -n "$slow_query_count" ] && [[ "$slow_query_count" =~ ^[0-9]+$ ]]; then
      if [ "$slow_query_count" -gt 10 ]; then
        colorize red "CRITICAL: $slow_query_count queries with mean time > 1000ms"
        issues=$((issues+1))
      elif [ "$slow_query_count" -gt 5 ]; then
        colorize yellow "WARNING: $slow_query_count queries with mean time > 1000ms"
        issues=$((issues+1))
      fi
    fi
  fi

  # Check table bloat
  local bloat_issues
  bloat_issues=$(cmd_bloat 10 2>/dev/null | tail -n +2 | awk '$4 > 30 { count++ } END { print count+0 }' 2>/dev/null || echo 0)
  if [[ "$bloat_issues" =~ ^[0-9]+$ ]]; then
    if [ "$bloat_issues" -gt 5 ]; then
      colorize yellow "WARNING: $bloat_issues tables with >30% bloat detected"
      issues=$((issues+1))
    fi
  fi

  # Check cache hit ratio - use direct query for current database
  local cache_ratio
  cache_ratio=$(q_scalar "SELECT round(100.0 * blks_hit / nullif(blks_hit + blks_read, 0), 2)
    FROM pg_stat_database WHERE datname = current_database();")
  if [[ "$cache_ratio" =~ ^[0-9]+\.?[0-9]*$ ]]; then
    if (( $(echo "$cache_ratio < 85" | bc -l) )); then
      colorize red "CRITICAL: Low cache hit ratio: ${cache_ratio}%"
      issues=$((issues+1))
    elif (( $(echo "$cache_ratio < 95" | bc -l) )); then
      colorize yellow "WARNING: Moderate cache hit ratio: ${cache_ratio}%"
      issues=$((issues+1))
    else
      echo "OK: Cache hit ratio: ${cache_ratio}%"
    fi
  fi

  if [ "$issues" -eq 0 ]; then
    colorize green "No critical issues detected - System healthy"
  fi
}

